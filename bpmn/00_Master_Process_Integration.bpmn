<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
id="Definitions_Master"
targetNamespace="http://bpmn.io/schema/bpmn">

<collaboration id="Master_Collaboration">
<participant id="Participant_AppointmentBooking" name="Diagram 2: Appointment Booking" processRef="Process_AppointmentBooking_Master"/>
<participant id="Participant_FormProcessing" name="Diagram 3: Form Processing" processRef="Process_FormProcessing_Master"/>
<participant id="Participant_PatientAdmission" name="Diagram 1: Patient Admission" processRef="Process_PatientAdmission_Master"/>

<!-- Message Flows between diagrams -->
<messageFlow id="MF_Master_1" name="Appointment Confirmed&#10;(Patient Arrives)" sourceRef="End_BookingComplete_Master" targetRef="Catch_PatientArrives_Master"/>
<messageFlow id="MF_Master_2" name="Pre-Visit Form Link Sent&#10;(Trigger Form Instance)" sourceRef="Send_FormLink_Master" targetRef="Catch_FormInstanceTrigger_Master"/>
<messageFlow id="MF_Master_3" name="Patient Notified&#10;(Form Available)" sourceRef="Service_NotifyPatient_Master" targetRef="Catch_FormAvailable_Master"/>
<messageFlow id="MF_Master_4" name="Section 1 Submitted" sourceRef="User_SubmitForm_Master" targetRef="Catch_Section1Submitted_Master"/>
<messageFlow id="MF_Master_5" name="Vital Signs Recorded" sourceRef="Service_RecordVitals_Master" targetRef="Catch_VitalsReceived_Master"/>
<messageFlow id="MF_Master_6" name="Consultation Ready&#10;(Patient Called)" sourceRef="Service_AssignConsultant_Master" targetRef="Catch_ConsultationReady_Master"/>
<messageFlow id="MF_Master_7" name="Section 2 Complete" sourceRef="End_Section2Complete_Master" targetRef="Catch_Section2Complete_Master"/>

<!-- Text annotations for documentation -->
<textAnnotation id="TextAnnotation_1">
<text>MASTER PROCESS OVERVIEW&#10;─&#10;Shows integration between 3 BPMN diagrams&#10;&#10;Note: This is an OPTIONAL overview diagram.&#10;The 3 individual diagrams (01, 02, 03)&#10;contain the complete process details.</text>
</textAnnotation>

</collaboration>

<!-- Pool 1: Appointment Booking Process (simplified from Diagram 2) -->
<process id="Process_AppointmentBooking_Master" isExecutable="false">
<startEvent id="Start_RequestAppointment_Master" name="Patient Requests&#10;Appointment"/>
<sequenceFlow id="Flow_AM1" sourceRef="Start_RequestAppointment_Master" targetRef="User_RequestAppointment_Master"/>

<userTask id="User_RequestAppointment_Master" name="Request Appointment&#10;(Select Date/Time)"/>
<sequenceFlow id="Flow_AM2" sourceRef="User_RequestAppointment_Master" targetRef="Gateway_DateAvailable_Master"/>

<exclusiveGateway id="Gateway_DateAvailable_Master" name="Date&#10;Available?"/>
<sequenceFlow id="Flow_AM3a" name="No" sourceRef="Gateway_DateAvailable_Master" targetRef="User_SelectAlternative_Master">
<conditionExpression xsi:type="tFormalExpression">${!dateAvailable}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_AM3b" name="Yes" sourceRef="Gateway_DateAvailable_Master" targetRef="Task_BlockSlot_Master">
<conditionExpression xsi:type="tFormalExpression">${dateAvailable}</conditionExpression>
</sequenceFlow>

<userTask id="User_SelectAlternative_Master" name="Select Alternative&#10;Date/Time"/>
<sequenceFlow id="Flow_AM4" sourceRef="User_SelectAlternative_Master" targetRef="User_RequestAppointment_Master"/>

<serviceTask id="Task_BlockSlot_Master" name="Admin: Block&#10;Appointment Slot"/>
<sequenceFlow id="Flow_AM5" sourceRef="Task_BlockSlot_Master" targetRef="Send_Confirmation_Master"/>

<sendTask id="Send_Confirmation_Master" name="Send Confirmation&#10;(Email/SMS)"/>
<sequenceFlow id="Flow_AM6" sourceRef="Send_Confirmation_Master" targetRef="Send_FormLink_Master"/>

<sendTask id="Send_FormLink_Master" name="Send Pre-Visit&#10;Form Link"/>
<sequenceFlow id="Flow_AM7" sourceRef="Send_FormLink_Master" targetRef="End_BookingComplete_Master"/>

<endEvent id="End_BookingComplete_Master" name="Appointment&#10;Confirmed"/>
</process>

<!-- Pool 2: Form Processing System (simplified from Diagram 3) -->
<process id="Process_FormProcessing_Master" isExecutable="false">
<!-- Main start event -->
<startEvent id="Start_FormProcess_Master" name="Form Instance&#10;Created"/>
<sequenceFlow id="Flow_FM1" sourceRef="Start_FormProcess_Master" targetRef="Service_CreateFormInstance_Master"/>

<serviceTask id="Service_CreateFormInstance_Master" name="Create Form Instance"/>
<sequenceFlow id="Flow_FM2" sourceRef="Service_CreateFormInstance_Master" targetRef="Service_AttachSection1_Master"/>

<serviceTask id="Service_AttachSection1_Master" name="Attach Section 1&#10;Template"/>
<sequenceFlow id="Flow_FM3" sourceRef="Service_AttachSection1_Master" targetRef="Service_MakeAvailable_Master"/>

<serviceTask id="Service_MakeAvailable_Master" name="Make Available to&#10;Patient Portal"/>
<sequenceFlow id="Flow_FM4" sourceRef="Service_MakeAvailable_Master" targetRef="Service_NotifyPatient_Master"/>

<serviceTask id="Service_NotifyPatient_Master" name="Notify Patient&#10;(Form Ready)"/>
<sequenceFlow id="Flow_FM5" sourceRef="Service_NotifyPatient_Master" targetRef="End_FormAvailable_Master"/>

<endEvent id="End_FormAvailable_Master" name="Patient&#10;Notified"/>

<!-- Catch for Section 1 submission from patient (intermediate catch, not start) -->
<intermediateCatchEvent id="Catch_Section1Submitted_Master" name="Section 1&#10;Submitted">
<messageEventDefinition id="MsgDef_FM1"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_FM10" sourceRef="Catch_Section1Submitted_Master" targetRef="Service_ValidateSection1_Master"/>

<serviceTask id="Service_ValidateSection1_Master" name="Validate Section 1"/>
<sequenceFlow id="Flow_FM11" sourceRef="Service_ValidateSection1_Master" targetRef="Gateway_Valid_Master"/>

<exclusiveGateway id="Gateway_Valid_Master" name="Section 1&#10;Valid?"/>
<sequenceFlow id="Flow_FM12" name="Yes" sourceRef="Gateway_Valid_Master" targetRef="Service_SaveSection1_Master">
<conditionExpression xsi:type="tFormalExpression">${section1Valid}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_FM13" name="No" sourceRef="Gateway_Valid_Master" targetRef="User_RequestCorr_Master">
<conditionExpression xsi:type="tFormalExpression">${!section1Valid}</conditionExpression>
</sequenceFlow>

<userTask id="User_RequestCorr_Master" name="Request&#10;Corrections"/>
<sequenceFlow id="Flow_FM14" sourceRef="User_RequestCorr_Master" targetRef="End_CorrectionsNeeded_Master"/>

<endEvent id="End_CorrectionsNeeded_Master" name="Corrections&#10;Required"/>

<serviceTask id="Service_SaveSection1_Master" name="Save Section 1&#10;(Patient Data)"/>
<sequenceFlow id="Flow_FM15" sourceRef="Service_SaveSection1_Master" targetRef="Service_AttachSection2_Master"/>

<serviceTask id="Service_AttachSection2_Master" name="Attach Section 2&#10;Template"/>
<sequenceFlow id="Flow_FM16" sourceRef="Service_AttachSection2_Master" targetRef="Service_AssignConsultant_Master"/>

<serviceTask id="Service_AssignConsultant_Master" name="Assign to Consultant&#10;(Add to Queue)"/>
<sequenceFlow id="Flow_FM17" sourceRef="Service_AssignConsultant_Master" targetRef="Catch_WaitSection2_Master"/>

<intermediateCatchEvent id="Catch_WaitSection2_Master" name="Wait for&#10;Section 2">
<messageEventDefinition id="MsgDef_FM2"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_FM18" sourceRef="Catch_WaitSection2_Master" targetRef="Service_SaveSection2_Master"/>

<serviceTask id="Service_SaveSection2_Master" name="Save Section 2&#10;(Clinical Data)"/>
<sequenceFlow id="Flow_FM19" sourceRef="Service_SaveSection2_Master" targetRef="Service_MergeData_Master"/>

<serviceTask id="Service_MergeData_Master" name="Merge Section 1 + 2&#10;(Complete Record)"/>
<sequenceFlow id="Flow_FM20" sourceRef="Service_MergeData_Master" targetRef="Service_UpdateRecord_Master"/>

<serviceTask id="Service_UpdateRecord_Master" name="Update Patient&#10;Medical Record"/>
<sequenceFlow id="Flow_FM21" sourceRef="Service_UpdateRecord_Master" targetRef="End_Section2Complete_Master"/>

<endEvent id="End_Section2Complete_Master" name="Medical Record&#10;Updated"/>

<!-- Vitals catch event -->
<intermediateCatchEvent id="Catch_VitalsReceived_Master" name="Vital Signs&#10;Received">
<messageEventDefinition id="MsgDef_FM3"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_FM22" sourceRef="Catch_VitalsReceived_Master" targetRef="Service_ValidateVitals_Master"/>

<serviceTask id="Service_ValidateVitals_Master" name="Validate Vital Signs"/>
<sequenceFlow id="Flow_FM23" sourceRef="Service_ValidateVitals_Master" targetRef="Service_UpdateVitals_Master"/>

<serviceTask id="Service_UpdateVitals_Master" name="Update Patient&#10;Medical Record"/>

<!-- Trigger to start form instance from appointment booking -->
<intermediateCatchEvent id="Catch_FormInstanceTrigger_Master" name="Trigger Form&#10;Instance Creation">
<messageEventDefinition id="MsgDef_FM4"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_FM24" sourceRef="Catch_FormInstanceTrigger_Master" targetRef="Start_FormProcess_Master"/>
</process>

<!-- Pool 3: Patient Admission Process (simplified from Diagram 1) -->
<process id="Process_PatientAdmission_Master" isExecutable="false">
<!-- Main start - patient arrival at clinic -->
<startEvent id="Start_PatientArrives_Master" name="Patient Arrives&#10;at Clinic"/>
<sequenceFlow id="Flow_PM1" sourceRef="Start_PatientArrives_Master" targetRef="User_VerifyIdentity_Master"/>

<userTask id="User_VerifyIdentity_Master" name="Verify Patient&#10;Identity"/>
<sequenceFlow id="Flow_PM2" sourceRef="User_VerifyIdentity_Master" targetRef="User_FillForm_Master"/>

<userTask id="User_FillForm_Master" name="Fill Section 1&#10;(Pre-Visit Form)"/>
<sequenceFlow id="Flow_PM3" sourceRef="User_FillForm_Master" targetRef="Gateway_FormComplete_Master"/>

<exclusiveGateway id="Gateway_FormComplete_Master" name="Form&#10;Complete?"/>
<sequenceFlow id="Flow_PM4a" name="No" sourceRef="Gateway_FormComplete_Master" targetRef="User_CompleteMissing_Master">
<conditionExpression xsi:type="tFormalExpression">${!formComplete}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_PM4b" name="Yes" sourceRef="Gateway_FormComplete_Master" targetRef="User_SubmitForm_Master">
<conditionExpression xsi:type="tFormalExpression">${formComplete}</conditionExpression>
</sequenceFlow>

<userTask id="User_CompleteMissing_Master" name="Complete Missing&#10;Fields"/>
<sequenceFlow id="Flow_PM5" sourceRef="User_CompleteMissing_Master" targetRef="User_FillForm_Master"/>

<userTask id="User_SubmitForm_Master" name="Submit Form"/>
<sequenceFlow id="Flow_PM6" sourceRef="User_SubmitForm_Master" targetRef="User_RecordVitals_Master"/>

<userTask id="User_RecordVitals_Master" name="Record Vital Signs&#10;(BP, BMI, Sugar)"/>
<sequenceFlow id="Flow_PM7" sourceRef="User_RecordVitals_Master" targetRef="Service_RecordVitals_Master"/>

<!-- Service task - automated recording -->
<serviceTask id="Service_RecordVitals_Master" name="Record in System"/>
<sequenceFlow id="Flow_PM8" sourceRef="Service_RecordVitals_Master" targetRef="User_EscortToConsultant_Master"/>

<userTask id="User_EscortToConsultant_Master" name="Escort to&#10;Consultant"/>
<sequenceFlow id="Flow_PM9" sourceRef="User_EscortToConsultant_Master" targetRef="Catch_ConsultationReady_Master"/>

<!-- Receive event - patient waits to be called -->
<intermediateCatchEvent id="Catch_ConsultationReady_Master" name="Called for&#10;Consultation">
<messageEventDefinition id="MsgDef_PM1"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_PM10" sourceRef="Catch_ConsultationReady_Master" targetRef="User_Consultation_Master"/>

<userTask id="User_Consultation_Master" name="Consultation with&#10;Specialist"/>
<sequenceFlow id="Flow_PM11" sourceRef="User_Consultation_Master" targetRef="Catch_ReceivePrescription_Master"/>

<!-- Receive event - patient receives prescription -->
<intermediateCatchEvent id="Catch_ReceivePrescription_Master" name="Receive&#10;Prescription">
<messageEventDefinition id="MsgDef_PM2"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_PM12" sourceRef="Catch_ReceivePrescription_Master" targetRef="End_VisitComplete_Master"/>

<endEvent id="End_VisitComplete_Master" name="Visit Complete"/>

<!-- Catch event for form availability notification -->
<intermediateCatchEvent id="Catch_FormAvailable_Master" name="Form Available&#10;Notification">
<messageEventDefinition id="MsgDef_PM3"/>
</intermediateCatchEvent>

<!-- Catch event for Section 2 completion notification -->
<intermediateCatchEvent id="Catch_Section2Complete_Master" name="Section 2&#10;Complete">
<messageEventDefinition id="MsgDef_PM4"/>
</intermediateCatchEvent>
</process>

<bpmndi:BPMNDiagram id="BPMNDiagram_Master">
<bpmndi:BPMNPlane id="BPMNPlane_Master" bpmnElement="Master_Collaboration">

