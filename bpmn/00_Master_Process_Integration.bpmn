<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Master" targetNamespace="http://bpmn.io/schema/bpmn">

  <collaboration id="Master_Collaboration">
    <participant id="Participant_AppointmentBooking" name="Diagram 2: Appointment Booking" processRef="Process_AppointmentBooking_Master"/>
    <participant id="Participant_FormProcessing" name="Diagram 3: Form Processing" processRef="Process_FormProcessing_Master"/>
    <participant id="Participant_PatientAdmission" name="Diagram 1: Patient Admission" processRef="Process_PatientAdmission_Master"/>

    <!-- Message Flows between diagrams -->
    <messageFlow id="MF_Master_1" name="Appointment Confirmed" sourceRef="End_BookingComplete_Master" targetRef="Catch_PatientArrives_Master"/>
    <messageFlow id="MF_Master_2" name="Form Link Sent" sourceRef="Send_FormLink_Master" targetRef="Catch_FormLinkReceived_Master"/>
    <messageFlow id="MF_Master_3" name="Patient Checked In" sourceRef="End_VerifyPatient_Master" targetRef="Start_FormFill_Master"/>
    <messageFlow id="MF_Master_4" name="Vitals Recorded" sourceRef="Service_RecordVitals_Master" targetRef="Catch_VitalsReady_Master"/>
    <messageFlow id="MF_Master_5" name="Patient Escorted" sourceRef="User_EscortToConsultant_Master" targetRef="Catch_PatientReady_Master"/>
    <messageFlow id="MF_Master_6" name="Prescription Ready" sourceRef="Service_GeneratePrescription_Master" targetRef="Catch_ReceivePrescription_Master"/>
  </collaboration>

  <!-- Pool 1: Appointment Booking Process -->
  <process id="Process_AppointmentBooking_Master" isExecutable="false">
    <startEvent id="Start_RequestAppointment_Master" name="Request&#10;Appointment"/>
    <sequenceFlow id="Flow_AM1" sourceRef="Start_RequestAppointment_Master" targetRef="User_RequestAppointment_Master"/>

    <userTask id="User_RequestAppointment_Master" name="Request Appointment&#10;(Select Date/Consultant)"/>
    <sequenceFlow id="Flow_AM2" sourceRef="User_RequestAppointment_Master" targetRef="Gateway_DateAvailable_Master"/>

    <exclusiveGateway id="Gateway_DateAvailable_Master" name="Slot&#10;Available?"/>
    <sequenceFlow id="Flow_AM3a" name="No" sourceRef="Gateway_DateAvailable_Master" targetRef="User_SelectAlternative_Master">
      <conditionExpression xsi:type="tFormalExpression">${!dateAvailable}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_AM3b" name="Yes" sourceRef="Gateway_DateAvailable_Master" targetRef="Service_BlockSlot_Master">
      <conditionExpression xsi:type="tFormalExpression">${dateAvailable}</conditionExpression>
    </sequenceFlow>

    <userTask id="User_SelectAlternative_Master" name="Select Alternative&#10;Date/Time"/>
    <sequenceFlow id="Flow_AM4" sourceRef="User_SelectAlternative_Master" targetRef="User_RequestAppointment_Master"/>

    <serviceTask id="Service_BlockSlot_Master" name="Block Appointment&#10;Slot"/>
    <sequenceFlow id="Flow_AM5" sourceRef="Service_BlockSlot_Master" targetRef="Send_Confirmation_Master"/>

    <sendTask id="Send_Confirmation_Master" name="Send Confirmation&#10;(Email/SMS)"/>
    <sequenceFlow id="Flow_AM6" sourceRef="Send_Confirmation_Master" targetRef="Send_FormLink_Master"/>

    <sendTask id="Send_FormLink_Master" name="Send Pre-Visit&#10;Form Link"/>
    <sequenceFlow id="Flow_AM7" sourceRef="Send_FormLink_Master" targetRef="End_BookingComplete_Master"/>

    <endEvent id="End_BookingComplete_Master" name="Appointment&#10;Confirmed"/>
  </process>

  <!-- Pool 2: Patient Admission & Consultation Process -->
  <process id="Process_PatientAdmission_Master" isExecutable="false">
    <intermediateCatchEvent id="Catch_PatientArrives_Master" name="Appointment&#10;Confirmed">
      <messageEventDefinition id="MsgDef_Appointment"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_PM1" sourceRef="Catch_PatientArrives_Master" targetRef="User_VerifyIdentity_Master"/>

    <userTask id="User_VerifyIdentity_Master" name="Verify Patient&#10;Identity"/>
    <sequenceFlow id="Flow_PM2" sourceRef="User_VerifyIdentity_Master" targetRef="End_VerifyPatient_Master"/>

    <endEvent id="End_VerifyPatient_Master" name="Patient&#10;Verified"/>

    <startEvent id="Start_FormFill_Master" name="Patient Checked&#10;In">
      <messageEventDefinition id="MsgDef_PatientCheckedIn"/>
    </startEvent>
    <sequenceFlow id="Flow_PM3" sourceRef="Start_FormFill_Master" targetRef="User_FillForm_Master"/>

    <userTask id="User_FillForm_Master" name="Fill Section 1&#10;(Symptoms, History)"/>
    <sequenceFlow id="Flow_PM4" sourceRef="User_FillForm_Master" targetRef="Gateway_FormComplete_Master"/>

    <exclusiveGateway id="Gateway_FormComplete_Master" name="Form&#10;Complete?"/>
    <sequenceFlow id="Flow_PM5a" name="No" sourceRef="Gateway_FormComplete_Master" targetRef="User_CompleteMissing_Master">
      <conditionExpression xsi:type="tFormalExpression">${!formComplete}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_PM5b" name="Yes" sourceRef="Gateway_FormComplete_Master" targetRef="User_SubmitForm_Master">
      <conditionExpression xsi:type="tFormalExpression">${formComplete}</conditionExpression>
    </sequenceFlow>

    <userTask id="User_CompleteMissing_Master" name="Complete Missing&#10;Fields"/>
    <sequenceFlow id="Flow_PM6" sourceRef="User_CompleteMissing_Master" targetRef="User_FillForm_Master"/>

    <userTask id="User_SubmitForm_Master" name="Submit Form"/>
    <sequenceFlow id="Flow_PM7" sourceRef="User_SubmitForm_Master" targetRef="User_RecordVitals_Master"/>

    <userTask id="User_RecordVitals_Master" name="Record Vital Signs&#10;(BP, BMI, Sugar)"/>
    <sequenceFlow id="Flow_PM8" sourceRef="User_RecordVitals_Master" targetRef="Service_RecordVitals_Master"/>

    <serviceTask id="Service_RecordVitals_Master" name="Save Vitals&#10;to System"/>
    <sequenceFlow id="Flow_PM9" sourceRef="Service_RecordVitals_Master" targetRef="User_EscortToConsultant_Master"/>

    <userTask id="User_EscortToConsultant_Master" name="Escort to&#10;Consultant"/>
    <sequenceFlow id="Flow_PM10" sourceRef="User_EscortToConsultant_Master" targetRef="Catch_PatientReady_Master"/>

    <intermediateCatchEvent id="Catch_PatientReady_Master" name="Patient&#10;Ready">
      <messageEventDefinition id="MsgDef_PatientReady"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_PM11" sourceRef="Catch_PatientReady_Master" targetRef="User_Consultation_Master"/>

    <userTask id="User_Consultation_Master" name="Consultation with&#10;Specialist"/>
    <sequenceFlow id="Flow_PM12" sourceRef="User_Consultation_Master" targetRef="Catch_ReceivePrescription_Master"/>

    <intermediateCatchEvent id="Catch_ReceivePrescription_Master" name="Receive&#10;Prescription">
      <messageEventDefinition id="MsgDef_Prescription"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_PM13" sourceRef="Catch_ReceivePrescription_Master" targetRef="End_VisitComplete_Master"/>

    <endEvent id="End_VisitComplete_Master" name="Visit&#10;Complete"/>
  </process>

  <!-- Pool 3: Form Processing & Clinical Tasks -->
  <process id="Process_FormProcessing_Master" isExecutable="false">
    <intermediateCatchEvent id="Catch_FormLinkReceived_Master" name="Form Link&#10;Received">
      <messageEventDefinition id="MsgDef_FormLink"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_FM1" sourceRef="Catch_FormLinkReceived_Master" targetRef="Service_ValidateSection1_Master"/>

    <intermediateCatchEvent id="Catch_VitalsReady_Master" name="Vital Signs&#10;Ready">
      <messageEventDefinition id="MsgDef_VitalsReady"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_FM2" sourceRef="Catch_VitalsReady_Master" targetRef="Gateway_ParallelReview_Master"/>

    <serviceTask id="Service_ValidateSection1_Master" name="Validate Section 1"/>
    <sequenceFlow id="Flow_FM3" sourceRef="Service_ValidateSection1_Master" targetRef="Gateway_ParallelReview_Master"/>

    <!-- Parallel Gateway: Both Section 1 and Vitals must be ready -->
    <parallelGateway id="Gateway_ParallelReview_Master" name="Section 1 &amp; Vitals&#10;Ready?"/>
    <sequenceFlow id="Flow_FM4a" sourceRef="Gateway_ParallelReview_Master" targetRef="User_ReviewSection1_Master"/>
    <sequenceFlow id="Flow_FM4b" sourceRef="Gateway_ParallelReview_Master" targetRef="Task_ReviewVitals_Master"/>

    <userTask id="User_ReviewSection1_Master" name="Review Section 1&#10;(Patient Data)"/>
    <sequenceFlow id="Flow_FM5" sourceRef="User_ReviewSection1_Master" targetRef="Gateway_JoinReview_Master"/>

    <userTask id="Task_ReviewVitals_Master" name="Review Vital Signs"/>
    <sequenceFlow id="Flow_FM6" sourceRef="Task_ReviewVitals_Master" targetRef="Gateway_JoinReview_Master"/>

    <parallelGateway id="Gateway_JoinReview_Master"/>
    <sequenceFlow id="Flow_FM7" sourceRef="Gateway_JoinReview_Master" targetRef="User_ConductExam_Master"/>

    <userTask id="User_ConductExam_Master" name="Conduct&#10;Examination"/>
    <sequenceFlow id="Flow_FM8" sourceRef="User_ConductExam_Master" targetRef="User_CompleteSection2_Master"/>

    <userTask id="User_CompleteSection2_Master" name="Complete Section 2&#10;(Diagnosis, Notes)"/>
    <sequenceFlow id="Flow_FM9" sourceRef="User_CompleteSection2_Master" targetRef="Gateway_Diagnosis_Master"/>

    <exclusiveGateway id="Gateway_Diagnosis_Master" name="Diagnosis&#10;Type?"/>
    <sequenceFlow id="Flow_FM10a" name="Hypertension" sourceRef="Gateway_Diagnosis_Master" targetRef="User_HypertensionPlan_Master">
      <conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypertension'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_FM10b" name="Hypotension" sourceRef="Gateway_Diagnosis_Master" targetRef="User_HypotensionPlan_Master">
      <conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypotension'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_FM10c" name="Diabetes" sourceRef="Gateway_Diagnosis_Master" targetRef="User_DiabetesPlan_Master">
      <conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Diabetes'}</conditionExpression>
    </sequenceFlow>

    <userTask id="User_HypertensionPlan_Master" name="Hypertension&#10;Treatment Plan"/>
    <sequenceFlow id="Flow_FM11" sourceRef="User_HypertensionPlan_Master" targetRef="Gateway_TreatmentJoin_Master"/>

    <userTask id="User_HypotensionPlan_Master" name="Hypotension&#10;Treatment Plan"/>
    <sequenceFlow id="Flow_FM12" sourceRef="User_HypotensionPlan_Master" targetRef="Gateway_TreatmentJoin_Master"/>

    <userTask id="User_DiabetesPlan_Master" name="Diabetes&#10;Management Plan"/>
    <sequenceFlow id="Flow_FM13" sourceRef="User_DiabetesPlan_Master" targetRef="Gateway_TreatmentJoin_Master"/>

    <exclusiveGateway id="Gateway_TreatmentJoin_Master" name="Treatment&#10;Planned"/>
    <sequenceFlow id="Flow_FM14" sourceRef="Gateway_TreatmentJoin_Master" targetRef="Service_GeneratePrescription_Master"/>

    <serviceTask id="Service_GeneratePrescription_Master" name="Generate&#10;Prescription"/>
    <sequenceFlow id="Flow_FM15" sourceRef="Service_GeneratePrescription_Master" targetRef="Service_SaveRecord_Master"/>

    <serviceTask id="Service_SaveRecord_Master" name="Save Medical&#10;Record"/>
    <sequenceFlow id="Flow_FM16" sourceRef="Service_SaveRecord_Master" targetRef="End_FormProcessComplete_Master"/>

    <endEvent id="End_FormProcessComplete_Master" name="Medical Record&#10;Updated"/>
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_Master">
    <bpmndi:BPMNPlane id="BPMNPlane_Master" bpmnElement="Master_Collaboration">

      <!-- Text Annotation -->
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <omgdc:Bounds x="20" y="20" width="220" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Appointment Booking Pool (Top) -->
      <bpmndi:BPMNShape id="Participant_AppointmentBooking_di" bpmnElement="Participant_AppointmentBooking" isHorizontal="true">
        <omgdc:Bounds x="250" y="0" width="950" height="160"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_RequestAppointment_Master_di" bpmnElement="Start_RequestAppointment_Master">
        <omgdc:Bounds x="280" y="60" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_RequestAppointment_Master_di" bpmnElement="User_RequestAppointment_Master">
        <omgdc:Bounds x="350" y="45" width="120" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DateAvailable_Master_di" bpmnElement="Gateway_DateAvailable_Master" isMarkerVisible="true">
        <omgdc:Bounds x="510" y="55" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_SelectAlternative_Master_di" bpmnElement="User_SelectAlternative_Master">
        <omgdc:Bounds x="500" y="110" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Service_BlockSlot_Master_di" bpmnElement="Service_BlockSlot_Master">
        <omgdc:Bounds x="590" y="45" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Send_Confirmation_Master_di" bpmnElement="Send_Confirmation_Master">
        <omgdc:Bounds x="720" y="45" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Send_FormLink_Master_di" bpmnElement="Send_FormLink_Master">
        <omgdc:Bounds x="850" y="45" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_BookingComplete_Master_di" bpmnElement="End_BookingComplete_Master">
        <omgdc:Bounds x="990" y="55" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Patient Admission Pool (Middle) -->
      <bpmndi:BPMNShape id="Participant_PatientAdmission_di" bpmnElement="Participant_PatientAdmission" isHorizontal="true">
        <omgdc:Bounds x="250" y="180" width="950" height="360"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch_PatientArrives_Master_di" bpmnElement="Catch_PatientArrives_Master">
        <omgdc:Bounds x="280" y="260" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_VerifyIdentity_Master_di" bpmnElement="User_VerifyIdentity_Master">
        <omgdc:Bounds x="350" y="250" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_VerifyPatient_Master_di" bpmnElement="End_VerifyPatient_Master">
        <omgdc:Bounds x="490" y="260" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_FormFill_Master_di" bpmnElement="Start_FormFill_Master">
        <omgdc:Bounds x="560" y="340" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_FillForm_Master_di" bpmnElement="User_FillForm_Master">
        <omgdc:Bounds x="630" y="320" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FormComplete_Master_di" bpmnElement="Gateway_FormComplete_Master" isMarkerVisible="true">
        <omgdc:Bounds x="770" y="330" width="40" height="40"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_CompleteMissing_Master_di" bpmnElement="User_CompleteMissing_Master">
        <omgdc:Bounds x="760" y="400" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_SubmitForm_Master_di" bpmnElement="User_SubmitForm_Master">
        <omgdc:Bounds x="850" y="320" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_RecordVitals_Master_di" bpmnElement="User_RecordVitals_Master">
        <omgdc:Bounds x="560" y="430" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Service_RecordVitals_Master_di" bpmnElement="Service_RecordVitals_Master">
        <omgdc:Bounds x="690" y="430" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_EscortToConsultant_Master_di" bpmnElement="User_EscortToConsultant_Master">
        <omgdc:Bounds x="820" y="430" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_PatientReady_Master_di" bpmnElement="Catch_PatientReady_Master">
        <omgdc:Bounds x="560" y="280" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_Consultation_Master_di" bpmnElement="User_Consultation_Master">
        <omgdc:Bounds x="630" y="260" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_ReceivePrescription_Master_di" bpmnElement="Catch_ReceivePrescription_Master">
        <omgdc:Bounds x="770" y="270" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_VisitComplete_Master_di" bpmnElement="End_VisitComplete_Master">
        <omgdc:Bounds x="850" y="270" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Form Processing Pool (Bottom) -->
      <bpmndi:BPMNShape id="Participant_FormProcessing_di" bpmnElement="Participant_FormProcessing" isHorizontal="true">
        <omgdc:Bounds x="250" y="560" width="950" height="280"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch_FormLinkReceived_Master_di" bpmnElement="Catch_FormLinkReceived_Master">
        <omgdc:Bounds x="280" y="600" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Service_ValidateSection1_Master_di" bpmnElement="Service_ValidateSection1_Master">
        <omgdc:Bounds x="350" y="590" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_VitalsReady_Master_di" bpmnElement="Catch_VitalsReady_Master">
        <omgdc:Bounds x="280" y="680" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ParallelReview_Master_di" bpmnElement="Gateway_ParallelReview_Master" isMarkerVisible="true">
        <omgdc:Bounds x="490" y="635" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_ReviewSection1_Master_di" bpmnElement="User_ReviewSection1_Master">
        <omgdc:Bounds x="580" y="580" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewVitals_Master_di" bpmnElement="Task_ReviewVitals_Master">
        <omgdc:Bounds x="580" y="680" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinReview_Master_di" bpmnElement="Gateway_JoinReview_Master" isMarkerVisible="true">
        <omgdc:Bounds x="720" y="635" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_ConductExam_Master_di" bpmnElement="User_ConductExam_Master">
        <omgdc:Bounds x="800" y="625" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_CompleteSection2_Master_di" bpmnElement="User_CompleteSection2_Master">
        <omgdc:Bounds x="930" y="625" width="100" height="60"/>
      </bpmndi:BPMNShape>

      <!-- Diagnosis branches -->
      <bpmndi:BPMNShape id="Gateway_Diagnosis_Master_di" bpmnElement="Gateway_Diagnosis_Master" isMarkerVisible="true">
        <omgdc:Bounds x="1070" y="635" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_HypertensionPlan_Master_di" bpmnElement="User_HypertensionPlan_Master">
        <omgdc:Bounds x="1070" y="550" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_HypotensionPlan_Master_di" bpmnElement="User_HypotensionPlan_Master">
        <omgdc:Bounds x="1070" y="710" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_DiabetesPlan_Master_di" bpmnElement="User_DiabetesPlan_Master">
        <omgdc:Bounds x="1170" y="635" width="100" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_TreatmentJoin_Master_di" bpmnElement="Gateway_TreatmentJoin_Master" isMarkerVisible="true">
        <omgdc:Bounds x="1070" y="760" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Service_GeneratePrescription_Master_di" bpmnElement="Service_GeneratePrescription_Master">
        <omgdc:Bounds x="930" y="760" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Service_SaveRecord_Master_di" bpmnElement="Service_SaveRecord_Master">
        <omgdc:Bounds x="800" y="760" width="100" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_FormProcessComplete_Master_di" bpmnElement="End_FormProcessComplete_Master">
        <omgdc:Bounds x="680" y="770" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Sequence Flow Connections - Appointment Booking -->
      <bpmndi:BPMNEdge id="Flow_AM1_di" bpmnElement="Flow_AM1">
        <omgdi:waypoint x="316" y="78"/>
        <omgdi:waypoint x="350" y="75"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AM2_di" bpmnElement="Flow_AM2">
        <omgdi:waypoint x="470" y="75"/>
        <omgdi:waypoint x="510" y="75"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AM3a_di" bpmnElement="Flow_AM3a">
        <omgdi:waypoint x="530" y="75"/>
        <omgdi:waypoint x="530" y="110"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AM3b_di" bpmnElement="Flow_AM3b">
        <omgdi:waypoint x="550" y="75"/>
        <omgdi:waypoint x="590" y="75"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AM4_di" bpmnElement="Flow_AM4">
        <omgdi:waypoint x="530" y="135"/>
        <omgdi:waypoint x="410" y="135"/>
        <omgdi:waypoint x="410" y="75"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AM5_di" bpmnElement="Flow_AM5">
        <omgdi:waypoint x="640" y="75"/>
        <omgdi:waypoint x="720" y="75"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AM6_di" bpmnElement="Flow_AM6">
        <omgdi:waypoint x="770" y="75"/>
        <omgdi:waypoint x="850" y="75"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AM7_di" bpmnElement="Flow_AM7">
        <omgdi:waypoint x="900" y="75"/>
        <omgdi:waypoint x="990" y="73"/>
      </bpmndi:BPMNEdge>

      <!-- Sequence Flow Connections - Patient Admission -->
      <bpmndi:BPMNEdge id="Flow_PM1_di" bpmnElement="Flow_PM1">
        <omgdi:waypoint x="298" y="278"/>
        <omgdi:waypoint x="350" y="280"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PM2_di" bpmnElement="Flow_PM2">
        <omgdi:waypoint x="400" y="280"/>
        <omgdi:waypoint x="490" y="278"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PM3_di" bpmnElement="Flow_PM3">
        <omgdi:waypoint x="578" y="358"/>
        <omgdi:waypoint x="630" y="350"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_PM4_di" bpmnElement="Flow_PM4">
        <omgdi:waypoint x="680" y="350"/>
        <omgdi:waypoint x="770" y="350"/>
