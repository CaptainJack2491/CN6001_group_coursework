<!-- Sequence Flow connections within pools -->
<!-- Appointment Booking -->
<bpmndi:BPMNEdge id="Flow_AM1_di" bpmnElement="Flow_AM1">
<omgdi:waypoint x="316" y="98"/>
<omgdi:waypoint x="340" y="95"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_AM2_di" bpmnElement="Flow_AM2">
<omgdi:waypoint x="440" y="95"/>
<omgdi:waypoint x="470" y="90"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_AM3a_di" bpmnElement="Flow_AM3a">
<omgdi:waypoint x="490" y="90"/>
<omgdi:waypoint x="490" y="150"/>
<omgdi:waypoint x="510" y="175"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_AM3b_di" bpmnElement="Flow_AM3b">
<omgdi:waypoint x="510" y="90"/>
<omgdi:waypoint x="540" y="95"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_AM4_di" bpmnElement="Flow_AM4">
<omgdi:waypoint x="510" y="175"/>
<omgdi:waypoint x="390" y="175"/>
<omgdi:waypoint x="390" y="130"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_AM5_di" bpmnElement="Flow_AM5">
<omgdi:waypoint x="590" y="95"/>
<omgdi:waypoint x="670" y="95"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_AM6_di" bpmnElement="Flow_AM6">
<omgdi:waypoint x="720" y="95"/>
<omgdi:waypoint x="800" y="95"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_AM7_di" bpmnElement="Flow_AM7">
<omgdi:waypoint x="850" y="95"/>
<omgdi:waypoint x="940" y="98"/>
</bpmndi:BPMNEdge>

<!-- Form Processing - Section 1 flow -->
<bpmndi:BPMNEdge id="Flow_FM20_di" bpmnElement="Flow_FM20">
<omgdi:waypoint x="786" y="278"/>
<omgdi:waypoint x="810" y="270"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_FM21_di" bpmnElement="Flow_FM21">
<omgdi:waypoint x="860" y="270"/>
<omgdi:waypoint x="940" y="270"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_FM22_di" bpmnElement="Flow_FM22">
<omgdi:waypoint x="960" y="270"/>
<omgdi:waypoint x="1010" y="270"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_FM23_di" bpmnElement="Flow_FM23">
<omgdi:waypoint x="960" y="290"/>
<omgdi:waypoint x="960" y="330"/>
<omgdi:waypoint x="980" y="355"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_FM25_di" bpmnElement="Flow_FM25">
<omgdi:waypoint x="1060" y="270"/>
<omgdi:waypoint x="1140" y="268"/>
</bpmndi:BPMNEdge>

<!-- Form Processing - Main flow -->
<bpmndi:BPMNEdge id="Flow_FM1_di" bpmnElement="Flow_FM1">
<omgdi:waypoint x="316" y="358"/>
<omgdi:waypoint x="340" y="350"/>
