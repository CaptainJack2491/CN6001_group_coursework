<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
id="Definitions_Master"
targetNamespace="http://bpmn.io/schema/bpmn">

<collaboration id="Master_Collaboration">
<participant id="Participant_AppointmentBooking" name="Diagram 2: Appointment Booking" processRef="Process_AppointmentBooking_Master"/>
<participant id="Participant_FormProcessing" name="Diagram 3: Form Processing" processRef="Process_FormProcessing_Master"/>
<participant id="Participant_PatientAdmission" name="Diagram 1: Patient Admission" processRef="Process_PatientAdmission_Master"/>

<!-- Message Flows between diagrams -->
<!-- Appointment Booking → Patient Admission -->
<messageFlow id="MF_Master_1" name="Appointment Confirmed&#10;(Patient Arrives)" sourceRef="End_BookingComplete_Master" targetRef="Start_PatientArrives_Master"/>

<!-- Appointment Booking → Form Processing -->
<messageFlow id="MF_Master_2" name="Pre-Visit Form Link Sent&#10;(Form Instance Created)" sourceRef="Task_SendFormLink_Master" targetRef="Start_FormProcess_Master"/>

<!-- Form Processing → Patient Admission -->
<messageFlow id="MF_Master_3" name="Section 1 Data Ready&#10;(Patient Notified)" sourceRef="Task_NotifyPatient_Master" targetRef="Start_FormAvailable_Master"/>

<!-- Patient Admission → Form Processing -->
<messageFlow id="MF_Master_4" name="Section 1 Submitted" sourceRef="Task_SubmitForm_Master" targetRef="Start_ReceiveSection1_Master"/>

<!-- Patient Admission → Form Processing (vitals data) -->
<messageFlow id="MF_Master_5" name="Vital Signs Recorded&#10;(Update Medical Record)" sourceRef="Task_RecordVitals_Master" targetRef="Start_VitalsReceived_Master"/>

<!-- Form Processing → Patient Admission (consultation ready) -->
<messageFlow id="MF_Master_6" name="Consultation Ready&#10;(Patient Called)" sourceRef="Task_AssignConsultant_Master" targetRef="Start_ConsultantAssigned_Master"/>

<!-- Form Processing → Patient Admission (section 2 complete) -->
<messageFlow id="MF_Master_7" name="Section 2 Complete&#10;(Consultant Done)" sourceRef="End_Section2Complete_Master" targetRef="Start_Section2Received_Master"/>

<!-- Text annotations for documentation -->
<textAnnotation id="TextAnnotation_1">
<text>MASTER PROCESS OVERVIEW&#10;─&#10;Shows how all 3 BPMN diagrams connect&#10;&#10;Diagram 1: Patient Admission Process&#10;Diagram 2: Appointment Booking Process&#10;Diagram 3: Form Processing &amp; Data Flow</text>
</textAnnotation>

</collaboration>

<!-- Pool 1: Appointment Booking Process (simplified from Diagram 2) -->
<process id="Process_AppointmentBooking_Master" isExecutable="false">
<startEvent id="Start_RequestAppointment_Master" name="Patient Requests&#10;Appointment"/>
<sequenceFlow id="Flow_AM1" sourceRef="Start_RequestAppointment_Master" targetRef="Task_RequestAppointment_Master"/>

<userTask id="Task_RequestAppointment_Master" name="Request Appointment&#10;(Select Date/Time)"/>
<sequenceFlow id="Flow_AM2" sourceRef="Task_RequestAppointment_Master" targetRef="Gateway_DateAvailable_Master"/>

<exclusiveGateway id="Gateway_DateAvailable_Master" name="Date&#10;Available?"/>
<sequenceFlow id="Flow_AM3a" name="No" sourceRef="Gateway_DateAvailable_Master" targetRef="Task_SelectAlternative_Master">
<conditionExpression xsi:type="tFormalExpression">${!dateAvailable}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_AM3b" name="Yes" sourceRef="Gateway_DateAvailable_Master" targetRef="Task_BlockSlot_Master">
<conditionExpression xsi:type="tFormalExpression">${dateAvailable}</conditionExpression>
</sequenceFlow>

<userTask id="Task_SelectAlternative_Master" name="Select Alternative&#10;Date/Time"/>
<sequenceFlow id="Flow_AM4" sourceRef="Task_SelectAlternative_Master" targetRef="Task_RequestAppointment_Master"/>

<userTask id="Task_BlockSlot_Master" name="Admin: Block&#10;Appointment Slot"/>
<sequenceFlow id="Flow_AM5" sourceRef="Task_BlockSlot_Master" targetRef="Task_SendConfirmation_Master"/>

<userTask id="Task_SendConfirmation_Master" name="Send Confirmation&#10;(Email/SMS)"/>
<sequenceFlow id="Flow_AM6" sourceRef="Task_SendConfirmation_Master" targetRef="Task_SendFormLink_Master"/>

<userTask id="Task_SendFormLink_Master" name="Send Pre-Visit&#10;Form Link"/>
<sequenceFlow id="Flow_AM7" sourceRef="Task_SendFormLink_Master" targetRef="End_BookingComplete_Master"/>

<endEvent id="End_BookingComplete_Master" name="Appointment&#10;Confirmed"/>
</process>

<!-- Pool 2: Form Processing System (simplified from Diagram 3) -->
<process id="Process_FormProcessing_Master" isExecutable="false">
<startEvent id="Start_FormProcess_Master" name="Form Instance&#10;Created"/>

<!-- Section 1 Processing Flow -->
<sequenceFlow id="Flow_FM1" sourceRef="Start_FormProcess_Master" targetRef="Task_CreateFormInstance_Master"/>
<serviceTask id="Task_CreateFormInstance_Master" name="Create Form Instance"/>
<sequenceFlow id="Flow_FM2" sourceRef="Task_CreateFormInstance_Master" targetRef="Task_MakeAvailable_Master"/>

<userTask id="Task_MakeAvailable_Master" name="Make Available to&#10;Patient Portal"/>
<sequenceFlow id="Flow_FM3" sourceRef="Task_MakeAvailable_Master" targetRef="Task_NotifyPatient_Master"/>

<userTask id="Task_NotifyPatient_Master" name="Notify Patient&#10;(Form Ready)"/>

<!-- Vital Signs Flow -->
<startEvent id="Start_VitalsReceived_Master" name="Vital Signs&#10;Received"/>
<sequenceFlow id="Flow_FM10" sourceRef="Start_VitalsReceived_Master" targetRef="Task_ValidateVitals_Master"/>
<serviceTask id="Task_ValidateVitals_Master" name="Validate Vital Signs"/>
<sequenceFlow id="Flow_FM11" sourceRef="Task_ValidateVitals_Master" targetRef="Task_UpdateVitals_Master"/>
<serviceTask id="Task_UpdateVitals_Master" name="Update Patient&#10;Medical Record"/>

<!-- Consultant Assignment Flow -->
<startEvent id="Start_ConsultantAssigned_Master" name="Consultant&#10;Assigned"/>
<sequenceFlow id="Flow_FM12" sourceRef="Start_ConsultantAssigned_Master" targetRef="Task_AssignConsultant_Master"/>

<userTask id="Task_AssignConsultant_Master" name="Assign to Consultant&#10;(Add to Queue)"/>
<sequenceFlow id="Flow_FM13" sourceRef="Task_AssignConsultant_Master" targetRef="Task_WaitSection2_Master"/>

<intermediateCatchEvent id="Task_WaitSection2_Master" name="Wait for&#10;Section 2">
<messageEventDefinition id="MessageEventDef_FM1"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_FM14" sourceRef="Task_WaitSection2_Master" targetRef="Task_SaveSection2_Master"/>

<serviceTask id="Task_SaveSection2_Master" name="Save Section 2&#10;(Clinical Data)"/>
<sequenceFlow id="Flow_FM15" sourceRef="Task_SaveSection2_Master" targetRef="Task_MergeData_Master"/>

<serviceTask id="Task_MergeData_Master" name="Merge Section 1 + 2&#10;(Complete Record)"/>
<sequenceFlow id="Flow_FM16" sourceRef="Task_MergeData_Master" targetRef="End_Section2Complete_Master"/>

<endEvent id="End_Section2Complete_Master" name="Medical Record&#10;Updated"/>

<!-- Catch for Section 1 submission from patient -->
<startEvent id="Start_ReceiveSection1_Master" name="Section 1&#10;Submitted">
<messageEventDefinition id="MessageEventDef_FM2"/>
</startEvent>
<sequenceFlow id="Flow_FM20" sourceRef="Start_ReceiveSection1_Master" targetRef="Task_ValidateSection1_Master"/>

<serviceTask id="Task_ValidateSection1_Master" name="Validate Section 1"/>
<sequenceFlow id="Flow_FM21" sourceRef="Task_ValidateSection1_Master" targetRef="Gateway_Valid_Master"/>

<exclusiveGateway id="Gateway_Valid_Master" name="Section 1&#10;Valid?"/>
<sequenceFlow id="Flow_FM22" name="Yes" sourceRef="Gateway_Valid_Master" targetRef="Task_SaveSection1_Master">
<conditionExpression xsi:type="tFormalExpression">${section1Valid}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_FM23" name="No" sourceRef="Gateway_Valid_Master" targetRef="Task_RequestCorr_Master">
<conditionExpression xsi:type="tFormalExpression">${!section1Valid}</conditionExpression>
</sequenceFlow>

<userTask id="Task_RequestCorr_Master" name="Request&#10;Corrections"/>
<sequenceFlow id="Flow_FM24" sourceRef="Task_RequestCorr_Master" targetRef="End_CorrectionsNeeded_Master"/>

<endEvent id="End_CorrectionsNeeded_Master" name="Corrections&#10;Required"/>

<serviceTask id="Task_SaveSection1_Master" name="Save Section 1&#10;(Patient Data)"/>
<sequenceFlow id="Flow_FM25" sourceRef="Task_SaveSection1_Master" targetRef="End_Section1Saved_Master"/>

<endEvent id="End_Section1Saved_Master" name="Section 1&#10;Complete"/>
</process>

<!-- Pool 3: Patient Admission Process (simplified from Diagram 1) -->
<process id="Process_PatientAdmission_Master" isExecutable="false">
<startEvent id="Start_PatientArrives_Master" name="Patient Arrives&#10;at Clinic"/>
<sequenceFlow id="Flow_PM1" sourceRef="Start_PatientArrives_Master" targetRef="Task_VerifyIdentity_Master"/>

<userTask id="Task_VerifyIdentity_Master" name="Verify Patient&#10;Identity"/>
<sequenceFlow id="Flow_PM2" sourceRef="Task_VerifyIdentity_Master" targetRef="Task_FillForm_Master"/>

<userTask id="Task_FillForm_Master" name="Fill Section 1&#10;(Pre-Visit Form)"/>
<sequenceFlow id="Flow_PM3" sourceRef="Task_FillForm_Master" targetRef="Gateway_FormComplete_Master"/>

<exclusiveGateway id="Gateway_FormComplete_Master" name="Form&#10;Complete?"/>
<sequenceFlow id="Flow_PM4a" name="No" sourceRef="Gateway_FormComplete_Master" targetRef="Task_CompleteMissing_Master">
<conditionExpression xsi:type="tFormalExpression">${!formComplete}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_PM4b" name="Yes" sourceRef="Gateway_FormComplete_Master" targetRef="Task_SubmitForm_Master">
<conditionExpression xsi:type="tFormalExpression">${formComplete}</conditionExpression>
</sequenceFlow>

<userTask id="Task_CompleteMissing_Master" name="Complete Missing&#10;Fields"/>
<sequenceFlow id="Flow_PM5" sourceRef="Task_CompleteMissing_Master" targetRef="Task_FillForm_Master"/>

<userTask id="Task_SubmitForm_Master" name="Submit Form"/>
<sequenceFlow id="Flow_PM6" sourceRef="Task_SubmitForm_Master" targetRef="Task_RecordVitals_Master"/>

<userTask id="Task_RecordVitals_Master" name="Record Vital Signs&#10;(BP, BMI, Sugar)"/>
<sequenceFlow id="Flow_PM7" sourceRef="Task_RecordVitals_Master" targetRef="Task_WaitConsultation_Master"/>

<userTask id="Task_WaitConsultation_Master" name="Wait for&#10;Consultation"/>
<sequenceFlow id="Flow_PM8" sourceRef="Task_WaitConsultation_Master" targetRef="Task_Consultation_Master"/>

<userTask id="Task_Consultation_Master" name="Consultation with&#10;Specialist"/>
<sequenceFlow id="Flow_PM9" sourceRef="Task_Consultation_Master" targetRef="Task_ReceivePrescription_Master"/>

<userTask id="Task_ReceivePrescription_Master" name="Receive&#10;Prescription"/>
<sequenceFlow id="Flow_PM10" sourceRef="Task_ReceivePrescription_Master" targetRef="End_VisitComplete_Master"/>

<endEvent id="End_VisitComplete_Master" name="Visit Complete"/>

<!-- Catch events for form availability notification -->
<startEvent id="Start_FormAvailable_Master" name="Form Available&#10;Notification">
<messageEventDefinition id="MessageEventDef_PM1"/>
</startEvent>

<!-- Catch for Section 2 completion -->
<startEvent id="Start_Section2Received_Master" name="Section 2&#10;Complete">
<messageEventDefinition id="MessageEventDef_PM2"/>
</startEvent>
</process>

<bpmndi:BPMNDiagram id="BPMNDiagram_Master">
<bpmndi:BPMNPlane id="BPMNPlane_Master" bpmnElement="Master_Collaboration">

<!-- Text Annotation -->
<bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
<omgdc:Bounds x="20" y="20" width="200" height="100"/>
</bpmndi:BPMNShape>

