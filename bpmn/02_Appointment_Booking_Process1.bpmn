<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
id="Definitions_2"
targetNamespace="http://bpmn.io/schema/bpmn">

<collaboration id="Collaboration_2">
<participant id="Participant_Patient2" name="Patient" processRef="Process_PatientBooking"/>
<participant id="Participant_Admin" name="Admin Staff" processRef="Process_AdminBooking"/>
<messageFlow id="MessageFlow_3" sourceRef="Task_RequestAppointment" targetRef="Start_Check"/>
<messageFlow id="MessageFlow_4" sourceRef="Task_SendConfirmation" targetRef="Task_ReceiveConfirmation"/>
<messageFlow id="MessageFlow_5" sourceRef="Task_SendFormLink" targetRef="Start_PreVisitForms"/>
</collaboration>

<!-- Patient Booking Process -->
<process id="Process_PatientBooking" isExecutable="false">
<startEvent id="Start_Request" name="Request Appointment Online"/>
<sequenceFlow id="Flow_30" sourceRef="Start_Request" targetRef="Task_RequestAppointment"/>

<userTask id="Task_RequestAppointment" name="Request Appointment Online&#10;(Select preferred date)"/>
<sequenceFlow id="Flow_31" sourceRef="Task_RequestAppointment" targetRef="Gateway_DateAvailable"/>

<exclusiveGateway id="Gateway_DateAvailable" name="Preferred Date Available?"/>
<sequenceFlow id="Flow_32" name="No" sourceRef="Gateway_DateAvailable" targetRef="Task_SelectAlternative">
<conditionExpression xsi:type="tFormalExpression">${!dateAvailable}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_33" name="Yes" sourceRef="Gateway_DateAvailable" targetRef="Task_ConfirmAppointment">
<conditionExpression xsi:type="tFormalExpression">${dateAvailable}</conditionExpression>
</sequenceFlow>

<userTask id="Task_SelectAlternative" name="Select Alternative Date"/>
<sequenceFlow id="Flow_34" sourceRef="Task_SelectAlternative" targetRef="Task_RequestAppointment"/>

<userTask id="Task_ConfirmAppointment" name="Confirm Appointment"/>
<sequenceFlow id="Flow_35" sourceRef="Task_ConfirmAppointment" targetRef="Task_ReceiveConfirmation"/>

<userTask id="Task_ReceiveConfirmation" name="Receive Confirmation&#10;(Email/SMS)"/>
<sequenceFlow id="Flow_36" sourceRef="Task_ReceiveConfirmation" targetRef="End_BookingComplete"/>

<endEvent id="End_BookingComplete" name="Appointment Confirmed"/>

<!-- Catch for Pre-Visit Form notification -->
<startEvent id="Start_PreVisitForms" name="Receive Pre-Visit Form Link">
<messageEventDefinition id="MessageEventDef_Patient"/>
</startEvent>
<sequenceFlow id="Flow_37" sourceRef="Start_PreVisitForms" targetRef="Task_CompletePreVisitForms"/>

<userTask id="Task_CompletePreVisitForms" name="Complete Pre-Visit Forms&#10;(Section 1)"/>
<sequenceFlow id="Flow_38" sourceRef="Task_CompletePreVisitForms" targetRef="End_FormsComplete"/>

<endEvent id="End_FormsComplete" name="Ready for Visit"/>
</process>

<!-- Admin Staff Process -->
<process id="Process_AdminBooking" isExecutable="false">
<!-- Start event triggered by message from Patient request -->
<intermediateCatchEvent id="Start_Check" name="Appointment Request Received">
<messageEventDefinition id="MessageEventDef_Admin"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_40" sourceRef="Start_Check" targetRef="Task_CheckSchedule"/>

<userTask id="Task_CheckSchedule" name="Check Consultant Schedule"/>
<sequenceFlow id="Flow_41" sourceRef="Task_CheckSchedule" targetRef="Task_BlockSlot"/>

<serviceTask id="Task_BlockSlot" name="Block Appointment Slot"/>
<sequenceFlow id="Flow_42" sourceRef="Task_BlockSlot" targetRef="Task_SendConfirmation"/>

<userTask id="Task_SendConfirmation" name="Send Confirmation Email/SMS"/>
<sequenceFlow id="Flow_43" sourceRef="Task_SendConfirmation" targetRef="Task_SendFormLink"/>

<userTask id="Task_SendFormLink" name="Send Pre-Visit Form Link"/>
<sequenceFlow id="Flow_44" sourceRef="Task_SendFormLink" targetRef="End_AdminComplete"/>

<endEvent id="End_AdminComplete" name="Booking Processed"/>
</process>

<bpmndi:BPMNDiagram id="BPMNDiagram_2">
<bpmndi:BPMNPlane id="BPMNPlane_2" bpmnElement="Collaboration_2">

<!-- Patient Pool -->
<bpmndi:BPMNShape id="Participant_Patient2_di" bpmnElement="Participant_Patient2" isHorizontal="true">
<omgdc:Bounds x="0" y="0" width="1000" height="300"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_Request_di" bpmnElement="Start_Request">
<omgdc:Bounds x="50" y="100" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_RequestAppointment_di" bpmnElement="Task_RequestAppointment">
<omgdc:Bounds x="120" y="78" width="140" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Gateway_DateAvailable_di" bpmnElement="Gateway_DateAvailable" isMarkerVisible="true">
<omgdc:Bounds x="300" y="95" width="50" height="50"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_SelectAlternative_di" bpmnElement="Task_SelectAlternative">
<omgdc:Bounds x="265" y="200" width="120" height="60"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_ConfirmAppointment_di" bpmnElement="Task_ConfirmAppointment">
<omgdc:Bounds x="400" y="78" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_ReceiveConfirmation_di" bpmnElement="Task_ReceiveConfirmation">
<omgdc:Bounds x="560" y="78" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_BookingComplete_di" bpmnElement="End_BookingComplete">
<omgdc:Bounds x="720" y="98" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Pre-visit forms flow (lower in Patient pool) -->
<bpmndi:BPMNShape id="Start_PreVisitForms_di" bpmnElement="Start_PreVisitForms">
<omgdc:Bounds x="400" y="220" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_CompletePreVisitForms_di" bpmnElement="Task_CompletePreVisitForms">
<omgdc:Bounds x="480" y="198" width="140" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_FormsComplete_di" bpmnElement="End_FormsComplete">
<omgdc:Bounds x="680" y="218" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Admin Pool -->
<bpmndi:BPMNShape id="Participant_Admin_di" bpmnElement="Participant_Admin" isHorizontal="true">
<omgdc:Bounds x="0" y="320" width="1000" height="220"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_Check_di" bpmnElement="Start_Check">
<omgdc:Bounds x="120" y="420" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_CheckSchedule_di" bpmnElement="Task_CheckSchedule">
<omgdc:Bounds x="200" y="398" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_BlockSlot_di" bpmnElement="Task_BlockSlot">
<omgdc:Bounds x="360" y="398" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_SendConfirmation_di" bpmnElement="Task_SendConfirmation">
<omgdc:Bounds x="520" y="398" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_SendFormLink_di" bpmnElement="Task_SendFormLink">
<omgdc:Bounds x="680" y="398" width="140" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_AdminComplete_di" bpmnElement="End_AdminComplete">
<omgdc:Bounds x="860" y="418" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Sequence Flows -->
<bpmndi:BPMNEdge id="Flow_30_di" bpmnElement="Flow_30">
<omgdi:waypoint x="86" y="118"/>
<omgdi:waypoint x="120" y="118"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_31_di" bpmnElement="Flow_31">
<omgdi:waypoint x="260" y="118"/>
<omgdi:waypoint x="300" y="120"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_32_di" bpmnElement="Flow_32">
<omgdi:waypoint x="325" y="120"/>
<omgdi:waypoint x="325" y="200"/>
<omgdi:waypoint x="325" y="230"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_33_di" bpmnElement="Flow_33">
<omgdi:waypoint x="350" y="120"/>
<omgdi:waypoint x="400" y="118"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_34_di" bpmnElement="Flow_34">
<omgdi:waypoint x="325" y="230"/>
<omgdi:waypoint x="180" y="230"/>
<omgdi:waypoint x="180" y="118"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_35_di" bpmnElement="Flow_35">
<omgdi:waypoint x="460" y="118"/>
<omgdi:waypoint x="560" y="118"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_36_di" bpmnElement="Flow_36">
<omgdi:waypoint x="620" y="118"/>
<omgdi:waypoint x="720" y="116"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_37_di" bpmnElement="Flow_37">
<omgdi:waypoint x="436" y="238"/>
<omgdi:waypoint x="480" y="238"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_38_di" bpmnElement="Flow_38">
<omgdi:waypoint x="560" y="238"/>
<omgdi:waypoint x="680" y="236"/>
</bpmndi:BPMNEdge>

<!-- Admin Flows -->
<bpmndi:BPMNEdge id="Flow_40_di" bpmnElement="Flow_40">
<omgdi:waypoint x="156" y="438"/>
<omgdi:waypoint x="200" y="438"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_41_di" bpmnElement="Flow_41">
<omgdi:waypoint x="260" y="438"/>
<omgdi:waypoint x="360" y="438"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_42_di" bpmnElement="Flow_42">
<omgdi:waypoint x="420" y="438"/>
<omgdi:waypoint x="520" y="438"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_43_di" bpmnElement="Flow_43">
<omgdi:waypoint x="580" y="438"/>
<omgdi:waypoint x="680" y="438"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="Flow_44_di" bpmnElement="Flow_44">
<omgdi:waypoint x="760" y="438"/>
<omgdi:waypoint x="860" y="436"/>
</bpmndi:BPMNEdge>

<!-- Message Flows -->
<bpmndi:BPMNEdge id="MessageFlow_3_di" bpmnElement="MessageFlow_3">
<omgdi:waypoint x="190" y="158"/>
<omgdi:waypoint x="138" y="420"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="MessageFlow_4_di" bpmnElement="MessageFlow_4">
<omgdi:waypoint x="580" y="478"/>
<omgdi:waypoint x="580" y="196"/>
</bpmndi:BPMNEdge>
<bpmndi:BPMNEdge id="MessageFlow_5_di" bpmnElement="MessageFlow_5">
<omgdi:waypoint x="750" y="478"/>
<omgdi:waypoint x="436" y="238"/>
</bpmndi:BPMNEdge>

</bpmndi:BPMNPlane>
</bpmndi:BPMNDiagram>
</definitions>