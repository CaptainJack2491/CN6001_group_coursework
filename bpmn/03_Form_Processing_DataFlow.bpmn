</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_NotifyPatientComplete_di" bpmnElement="Task_NotifyPatientComplete">
<omgdc:Bounds x="1010" y="328" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_FormProcessComplete_di" bpmnElement="End_FormProcessComplete">
<omgdc:Bounds x="1170" y="350" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Data Objects -->
<bpmndi:BPMNShape id="DataObject_Section1Form_di" bpmnElement="DataObjectRef_Section1">
<omgdc:Bounds x="980" y="100" width="36" height="50"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="DataObject_Section2Form_di" bpmnElement="DataObjectRef_Section2">
<omgdc:Bounds x="320" y="250" width="36" height="50"/>
</bpmndi:BPMNShape>
