<omgdc:Bounds x="700" y="480" width="800" height="180"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_ConsultantNotified_di" bpmnElement="Start_ConsultantNotified">
<omgdc:Bounds x="750" y="530" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_ConsultantReviews_di" bpmnElement="Task_ConsultantReviews">
<omgdc:Bounds x="840" y="508" width="120" height="80"/>
</bpmndi:BPMNShape>
