<omgdc:Bounds x="600" y="200" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_ValidateSection1_di" bpmnElement="Task_ValidateSection1">
<omgdc:Bounds x="680" y="178" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Gateway_Section1Valid_di" bpmnElement="Gateway_Section1Valid" isMarkerVisible="true">
<omgdc:Bounds x="840" y="195" width="50" height="50"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_RequestCorrections_di" bpmnElement="Task_RequestCorrections">
<omgdc:Bounds x="805" y="300" width="120" height="60"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_SaveSection1Data_di" bpmnElement="Task_SaveSection1Data">
<omgdc:Bounds x="940" y="178" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_AttachSection2Template_di" bpmnElement="Task_AttachSection2Template">
<omgdc:Bounds x="1100" y="178" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_AssignToConsultant_di" bpmnElement="Task_AssignToConsultant">
<omgdc:Bounds x="1260" y="178" width="120" height="80"/>
</bpmndi:BPMNShape>

<!-- Second Row -->
<bpmndi:BPMNShape id="Task_WaitForSection2_di" bpmnElement="Task_WaitForSection2">
<omgdc:Bounds x="50" y="350" width="36" height="36"/>
</bpmndi:BPMNShape>
