</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_ConsultantDone_di" bpmnElement="End_ConsultantDone">
<omgdc:Bounds x="1180" y="530" width="36" height="36"/>
</bpmndi:BPMNShape>

