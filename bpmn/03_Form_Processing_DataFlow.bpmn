<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
id="Definitions_3"
targetNamespace="http://bpmn.io/schema/bpmn">

<collaboration id="Collaboration_3">
<participant id="Participant_System" name="CVD Clinic System" processRef="Process_FormFlow"/>
<participant id="Participant_ExternalPatient" name="Patient (External)" processRef="Process_ExternalPatient"/>
<participant id="Participant_ExternalConsultant" name="Consultant (External)" processRef="Process_ExternalConsultant"/>

<messageFlow id="MF_FormAvailable" sourceRef="Service_MakeAvailable" targetRef="Start_PatientNotified"/>
<messageFlow id="MF_Section1Submitted" sourceRef="User_PatientCreatesSection1" targetRef="Catch_Section1Received"/>
<messageFlow id="MF_AssignedToConsultant" sourceRef="Service_AssignToConsultant" targetRef="Start_ConsultantNotified"/>
<messageFlow id="MF_ProcessComplete" sourceRef="Service_NotifyPatientComplete" targetRef="Start_PatientFormComplete"/>
</collaboration>

<!-- Main System Process -->
<process id="Process_FormFlow" isExecutable="false">
<startEvent id="Start_FormProcess" name="New Form&#10;Process Started"/>
<sequenceFlow id="Flow_50" sourceRef="Start_FormProcess" targetRef="Service_CreateFormInstance"/>

<!-- Service task - automated form instance creation -->
<serviceTask id="Service_CreateFormInstance" name="Create Form Instance&#10;(Generate Form ID)"/>
<sequenceFlow id="Flow_51" sourceRef="Service_CreateFormInstance" targetRef="Service_AttachSection1Template"/>

<!-- Service task - automated template attachment -->
<serviceTask id="Service_AttachSection1Template" name="Attach Section 1 Template&#10;(Patient Input Fields)"/>
<sequenceFlow id="Flow_52" sourceRef="Service_AttachSection1Template" targetRef="Service_MakeAvailable"/>

<!-- Service task - automated system action to publish to portal -->
<serviceTask id="Service_MakeAvailable" name="Make Available to&#10;Patient Portal"/>
<sequenceFlow id="Flow_53" sourceRef="Service_MakeAvailable" targetRef="Catch_WaitForSection1"/>

<!-- Intermediate catch - wait for Section 1 completion -->
<intermediateCatchEvent id="Catch_WaitForSection1" name="Wait for&#10;Section 1 Completion">
<messageEventDefinition id="MsgDef_Section1"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_54" sourceRef="Catch_WaitForSection1" targetRef="Service_ValidateSection1"/>

<!-- Service task - automated validation -->
<serviceTask id="Service_ValidateSection1" name="Validate Section 1&#10;(Required Fields Check)"/>
<sequenceFlow id="Flow_55" sourceRef="Service_ValidateSection1" targetRef="Gateway_Section1Valid"/>

<exclusiveGateway id="Gateway_Section1Valid" name="Section 1 Valid?"/>
<sequenceFlow id="Flow_56" name="No" sourceRef="Gateway_Section1Valid" targetRef="User_RequestCorrections">
<conditionExpression xsi:type="tFormalExpression">${!section1Valid}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_57" name="Yes" sourceRef="Gateway_Section1Valid" targetRef="Service_SaveSection1Data">
<conditionExpression xsi:type="tFormalExpression">${section1Valid}</conditionExpression>
</sequenceFlow>

<!-- User task - staff requests corrections -->
<userTask id="User_RequestCorrections" name="Request Corrections&#10;from Patient"/>
<sequenceFlow id="Flow_58" sourceRef="User_RequestCorrections" targetRef="Catch_WaitForSection1"/>

<!-- Service task - automated database save -->
<serviceTask id="Service_SaveSection1Data" name="Save Section 1 Data&#10;(Patient Database)"/>
<sequenceFlow id="Flow_59" sourceRef="Service_SaveSection1Data" targetRef="Service_AttachSection2Template"/>

<!-- Service task - automated template attachment -->
<serviceTask id="Service_AttachSection2Template" name="Attach Section 2 Template&#10;(Clinical Assessment Fields)"/>
<sequenceFlow id="Flow_60" sourceRef="Service_AttachSection2Template" targetRef="Service_AssignToConsultant"/>

<!-- Service task - automated work queue assignment -->
<serviceTask id="Service_AssignToConsultant" name="Assign to Consultant&#10;(Add to Work Queue)"/>
<sequenceFlow id="Flow_61" sourceRef="Service_AssignToConsultant" targetRef="Catch_WaitForSection2"/>

<!-- Intermediate catch - wait for Section 2 completion -->
<intermediateCatchEvent id="Catch_WaitForSection2" name="Wait for&#10;Section 2 Completion">
<messageEventDefinition id="MsgDef_Section2"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_62" sourceRef="Catch_WaitForSection2" targetRef="Service_ValidateSection2"/>

<!-- Service task - automated validation -->
<serviceTask id="Service_ValidateSection2" name="Validate Section 2&#10;(Clinical Notes, Diagnosis)"/>
<sequenceFlow id="Flow_63" sourceRef="Service_ValidateSection2" targetRef="Gateway_Section2Valid"/>

<exclusiveGateway id="Gateway_Section2Valid" name="Section 2 Valid?"/>
<sequenceFlow id="Flow_64a" name="No" sourceRef="Gateway_Section2Valid" targetRef="User_RequestSection2Corr">
<conditionExpression xsi:type="tFormalExpression">${!section2Valid}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_64b" name="Yes" sourceRef="Gateway_Section2Valid" targetRef="Service_SaveSection2Data">
<conditionExpression xsi:type="tFormalExpression">${section2Valid}</conditionExpression>
</sequenceFlow>

<!-- User task - staff requests corrections -->
<userTask id="User_RequestSection2Corr" name="Request Section 2&#10;Corrections from Consultant"/>
<sequenceFlow id="Flow_64c" sourceRef="User_RequestSection2Corr" targetRef="Catch_WaitForSection2"/>

<!-- Service task - automated database save -->
<serviceTask id="Service_SaveSection2Data" name="Save Section 2 Data&#10;(Clinical Database)"/>
<sequenceFlow id="Flow_65" sourceRef="Service_SaveSection2Data" targetRef="Service_MergeSections"/>

<!-- Service task - automated data merge -->
<serviceTask id="Service_MergeSections" name="Merge Section 1 + Section 2&#10;(Create Complete Record)"/>
<sequenceFlow id="Flow_66" sourceRef="Service_MergeSections" targetRef="Service_UpdateMedicalRecord"/>

<!-- Service task - automated record update -->
<serviceTask id="Service_UpdateMedicalRecord" name="Update Patient&#10;Medical Record"/>
<sequenceFlow id="Flow_67" sourceRef="Service_UpdateMedicalRecord" targetRef="Service_GeneratePrescriptionData"/>

<!-- Service task - automated prescription generation -->
<serviceTask id="Service_GeneratePrescriptionData" name="Generate Prescription&#10;(if required)"/>
<sequenceFlow id="Flow_68" sourceRef="Service_GeneratePrescriptionData" targetRef="Service_NotifyPatientComplete"/>

<!-- Service task - automated notification -->
<serviceTask id="Service_NotifyPatientComplete" name="Notify Patient&#10;(Form Complete)"/>
<sequenceFlow id="Flow_69" sourceRef="Service_NotifyPatientComplete" targetRef="End_FormProcessComplete"/>

<endEvent id="End_FormProcessComplete" name="Medical Record&#10;Updated"/>

<!-- Data Objects -->
<dataObject id="DataObject_Section1" name="Patient Section 1 Data"/>
<dataObject id="DataObject_Section2" name="Consultant Section 2 Data"/>
<dataObject id="DataObject_Complete" name="Complete Patient Record"/>
<dataObject id="DataObject_Presc" name="Prescription Document"/>

<dataObjectReference id="DataObjectRef_Section1" dataObjectRef="DataObject_Section1" name="Section 1 Form"/>
<dataObjectReference id="DataObjectRef_Section2" dataObjectRef="DataObject_Section2" name="Section 2 Form"/>
<dataObjectReference id="DataObjectRef_Complete" dataObjectRef="DataObject_Complete" name="Complete Medical Record"/>
<dataObjectReference id="DataObjectRef_Prescription" dataObjectRef="DataObject_Presc" name="Prescription"/>

</process>

<!-- External Patient Process -->
<process id="Process_ExternalPatient" isExecutable="false">
<startEvent id="Start_PatientNotified" name="Form Available&#10;Notification">
<messageEventDefinition id="MsgDef_PatientNotified"/>
</startEvent>
<sequenceFlow id="Flow_70" sourceRef="Start_PatientNotified" targetRef="User_PatientCreatesSection1"/>

<!-- User task - patient actively fills form -->
<userTask id="User_PatientCreatesSection1" name="Patient Fills Section 1&#10;(Submit Data)"/>
<sequenceFlow id="Flow_71" sourceRef="User_PatientCreatesSection1" targetRef="End_PatientDone"/>

<endEvent id="End_PatientDone" name="Section 1&#10;Submitted"/>

<!-- Catch for final notification -->
<startEvent id="Start_PatientFormComplete" name="Form Process&#10;Complete">
<messageEventDefinition id="MsgDef_ProcessComplete"/>
</startEvent>
<sequenceFlow id="Flow_72" sourceRef="Start_PatientFormComplete" targetRef="End_PatientComplete"/>

<endEvent id="End_PatientComplete" name="Patient&#10;Notified"/>
</process>

<!-- External Consultant Process -->
<process id="Process_ExternalConsultant" isExecutable="false">
<startEvent id="Start_ConsultantNotified" name="Assigned to Review">
<messageEventDefinition id="MsgDef_ConsultantNotified"/>
</startEvent>
<sequenceFlow id="Flow_80" sourceRef="Start_ConsultantNotified" targetRef="User_ConsultantReviews"/>

<!-- User task - consultant reviews patient data -->
<userTask id="User_ConsultantReviews" name="Review Section 1&#10;(Patient Data)"/>
<sequenceFlow id="Flow_81" sourceRef="User_ConsultantReviews" targetRef="User_ConsultantCreatesSection2"/>

<!-- User task - consultant completes assessment -->
<userTask id="User_ConsultantCreatesSection2" name="Complete Section 2&#10;(Clinical Assessment)"/>
<sequenceFlow id="Flow_82" sourceRef="User_ConsultantCreatesSection2" targetRef="End_ConsultantDone"/>

<endEvent id="End_ConsultantDone" name="Section 2&#10;Submitted"/>
</process>

<bpmndi:BPMNDiagram id="BPMNDiagram_3">
<bpmndi:BPMNPlane id="BPMNPlane_3" bpmnElement="Collaboration_3">

<!-- System Pool -->
<bpmndi:BPMNShape id="Participant_System_di" bpmnElement="Participant_System" isHorizontal="true">
<omgdc:Bounds x="0" y="0" width="1500" height="450"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_FormProcess_di" bpmnElement="Start_FormProcess">
<omgdc:Bounds x="50" y="200" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Service_CreateFormInstance_di" bpmnElement="Service_CreateFormInstance">
<omgdc:Bounds x="120" y="178" width="120" height="80"/>
</bpmndi:BPMNShape>
