<omgdc:Bounds x="840" y="195" width="50" height="50"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="User_RequestCorrections_di" bpmnElement="User_RequestCorrections">
<omgdc:Bounds x="805" y="300" width="120" height="60"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Service_SaveSection1Data_di" bpmnElement="Service_SaveSection1Data">
<omgdc:Bounds x="940" y="178" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Service_AttachSection2Template_di" bpmnElement="Service_AttachSection2Template">
<omgdc:Bounds x="1100" y="178" width="120" height="80"/>
</bpmndi:BPMNShape>
