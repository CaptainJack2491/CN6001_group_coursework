<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_3" targetNamespace="http://bpmn.io/schema/bpmn">

  <collaboration id="Collaboration_3">
    <participant id="Participant_Patient3" name="Patient" processRef="Process_Patient3"/>
    <participant id="Participant_Nurse" name="Nurse / Admin" processRef="Process_NurseAdmin"/>
    <participant id="Participant_Consultant3" name="Consultant" processRef="Process_Consultant3"/>

    <!-- Message Flows -->
    <messageFlow id="MF_PatientArrives" sourceRef="Start_CheckIn" targetRef="Catch_PatientArrives"/>
    <messageFlow id="MF_VitalsReady" sourceRef="Task_RecordVitals" targetRef="Catch_VitalsReceived"/>
    <messageFlow id="MF_EscortToConsultant" sourceRef="User_EscortPatient" targetRef="Catch_PatientArrivedConsultant"/>
    <messageFlow id="MF_PrescriptionReady" sourceRef="Task_GeneratePrescription" targetRef="Catch_ReceivePrescription"/>
    <messageFlow id="MF_Section1Data" sourceRef="User_FillSection1" targetRef="Task_ReviewSection1"/>
  </collaboration>

  <!-- Patient Process -->
  <process id="Process_Patient3" isExecutable="false">
    <startEvent id="Start_CheckIn" name="Check In&#10;at Clinic"/>
    <sequenceFlow id="Flow_P1" sourceRef="Start_CheckIn" targetRef="User_WaitVitals"/>

    <userTask id="User_WaitVitals" name="Wait for&#10;Vital Signs Check"/>
    <sequenceFlow id="Flow_P2" sourceRef="User_WaitVitals" targetRef="User_WaitConsultation"/>

    <userTask id="User_WaitConsultation" name="Wait for&#10;Consultation"/>
    <sequenceFlow id="Flow_P3" sourceRef="User_WaitConsultation" targetRef="User_Consultation"/>

    <userTask id="User_Consultation" name="Consultation with&#10;Specialist"/>
    <sequenceFlow id="Flow_P4" sourceRef="User_Consultation" targetRef="Catch_ReceivePrescription"/>

    <intermediateCatchEvent id="Catch_ReceivePrescription" name="Receive&#10;Prescription">
      <messageEventDefinition id="MsgDef_Prescription"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_P5" sourceRef="Catch_ReceivePrescription" targetRef="User_FillSection1"/>

    <userTask id="User_FillSection1" name="Fill Section 1&#10;(Symptoms, History)"/>
    <sequenceFlow id="Flow_P6" sourceRef="User_FillSection1" targetRef="End_PatientComplete"/>

    <endEvent id="End_PatientComplete" name="Visit&#10;Complete"/>
  </process>

  <!-- Nurse / Admin Process -->
  <process id="Process_NurseAdmin" isExecutable="false">
    <intermediateCatchEvent id="Catch_PatientArrives" name="Patient&#10;Arrives">
      <messageEventDefinition id="MsgDef_PatientArrives"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_N1" sourceRef="Catch_PatientArrives" targetRef="User_VerifyIdentity"/>

    <userTask id="User_VerifyIdentity" name="Verify Patient&#10;Identity"/>
    <sequenceFlow id="Flow_N2" sourceRef="User_VerifyIdentity" targetRef="User_RecordVitals"/>

    <userTask id="User_RecordVitals" name="Record Vital Signs&#10;(BP, BMI, Blood Sugar)"/>
    <sequenceFlow id="Flow_N3" sourceRef="User_RecordVitals" targetRef="Task_RecordVitalsSystem"/>

    <serviceTask id="Task_RecordVitalsSystem" name="Save Vital Signs&#10;to System"/>
    <sequenceFlow id="Flow_N4" sourceRef="Task_RecordVitalsSystem" targetRef="User_EscortPatient"/>

    <userTask id="User_EscortPatient" name="Escort Patient to&#10;Consultant"/>
    <sequenceFlow id="Flow_N5" sourceRef="User_EscortPatient" targetRef="End_NurseComplete"/>

    <endEvent id="End_NurseComplete" name="Handover&#10;Complete"/>
  </process>

  <!-- Consultant Process -->
  <process id="Process_Consultant3" isExecutable="false">
    <intermediateCatchEvent id="Catch_PatientArrivedConsultant" name="Patient&#10;Arrived">
      <messageEventDefinition id="MsgDef_PatientHere"/>
    </intermediateCatchEvent>
    <sequenceFlow id="Flow_C1" sourceRef="Catch_PatientArrivedConsultant" targetRef="Gateway_ParallelReview"/>

    <!-- Parallel Gateway: Review Section 1 AND Vital Signs simultaneously -->
    <parallelGateway id="Gateway_ParallelReview" name="Review Section 1&#10;&amp; Vitals in Parallel"/>
    <sequenceFlow id="Flow_C2a" sourceRef="Gateway_ParallelReview" targetRef="Task_ReviewSection1"/>
    <sequenceFlow id="Flow_C2b" sourceRef="Gateway_ParallelReview" targetRef="Task_ReviewVitals"/>

    <userTask id="Task_ReviewSection1" name="Review Section 1&#10;(Patient Data)"/>
    <sequenceFlow id="Flow_C3" sourceRef="Task_ReviewSection1" targetRef="Gateway_JoinReview"/>

    <userTask id="Task_ReviewVitals" name="Review Vital Signs&#10;(BP, BMI, Sugar)"/>
    <sequenceFlow id="Flow_C4" sourceRef="Task_ReviewVitals" targetRef="Gateway_JoinReview"/>

    <parallelGateway id="Gateway_JoinReview"/>
    <sequenceFlow id="Flow_C5" sourceRef="Gateway_JoinReview" targetRef="User_ConductExam"/>

    <userTask id="User_ConductExam" name="Conduct&#10;Examination"/>
    <sequenceFlow id="Flow_C6" sourceRef="User_ConductExam" targetRef="User_CompleteSection2"/>

    <userTask id="User_CompleteSection2" name="Complete Section 2&#10;(Diagnosis &amp; Notes)"/>
    <sequenceFlow id="Flow_C7" sourceRef="User_CompleteSection2" targetRef="Gateway_Diagnosis"/>

    <!-- Exclusive Gateway: Diagnosis Type -->
    <exclusiveGateway id="Gateway_Diagnosis" name="Diagnosis&#10;Type?"/>
    <sequenceFlow id="Flow_C8a" name="Hypertension" sourceRef="Gateway_Diagnosis" targetRef="User_HypertensionPlan">
      <conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypertension'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_C8b" name="Hypotension" sourceRef="Gateway_Diagnosis" targetRef="User_HypotensionPlan">
      <conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypotension'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_C8c" name="Diabetes" sourceRef="Gateway_Diagnosis" targetRef="User_DiabetesPlan">
      <conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Diabetes'}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="Flow_C8d" name="General" sourceRef="Gateway_Diagnosis" targetRef="User_GeneralPlan">
      <conditionExpression xsi:type="tFormalExpression">${diagnosis == 'General'}</conditionExpression>
    </sequenceFlow>

    <userTask id="User_HypertensionPlan" name="Hypertension&#10;Treatment Plan"/>
    <sequenceFlow id="Flow_C9" sourceRef="User_HypertensionPlan" targetRef="Gateway_TreatmentJoin"/>

    <userTask id="User_HypotensionPlan" name="Hypotension&#10;Treatment Plan"/>
    <sequenceFlow id="Flow_C10" sourceRef="User_HypotensionPlan" targetRef="Gateway_TreatmentJoin"/>

    <userTask id="User_DiabetesPlan" name="Diabetes&#10;Management Plan"/>
    <sequenceFlow id="Flow_C11" sourceRef="User_DiabetesPlan" targetRef="Gateway_TreatmentJoin"/>

    <userTask id="User_GeneralPlan" name="General&#10;Care Plan"/>
    <sequenceFlow id="Flow_C12" sourceRef="User_GeneralPlan" targetRef="Gateway_TreatmentJoin"/>

    <!-- Converging Gateway -->
    <exclusiveGateway id="Gateway_TreatmentJoin" name="Treatment&#10;Planned"/>
    <sequenceFlow id="Flow_C13" sourceRef="Gateway_TreatmentJoin" targetRef="Task_GeneratePrescription"/>

    <!-- Service Task: Auto-generate prescription -->
    <serviceTask id="Task_GeneratePrescription" name="Generate&#10;Prescription"/>
    <sequenceFlow id="Flow_C14" sourceRef="Task_GeneratePrescription" targetRef="User_ScheduleFollowup"/>

    <userTask id="User_ScheduleFollowup" name="Schedule&#10;Follow-up"/>
    <sequenceFlow id="Flow_C15" sourceRef="User_ScheduleFollowup" targetRef="Task_SaveRecord"/>

    <serviceTask id="Task_SaveRecord" name="Save Medical&#10;Record"/>
    <sequenceFlow id="Flow_C16" sourceRef="Task_SaveRecord" targetRef="End_ConsultantComplete"/>

    <endEvent id="End_ConsultantComplete" name="Consultation&#10;Complete"/>

    <!-- Catch for vitals received -->
    <intermediateCatchEvent id="Catch_VitalsReceived" name="Vital Signs&#10;Received">
      <messageEventDefinition id="MsgDef_Vitals"/>
    </intermediateCatchEvent>
  </process>

  <!-- Data Objects -->
  <dataObject id="DataObject_Section1" name="Section 1 Form"/>
  <dataObject id="DataObject_VitalSigns" name="Vital Signs Record"/>
  <dataObject id="DataObject_Section2" name="Section 2 Form"/>
  <dataObject id="DataObject_Prescription" name="Prescription"/>

  <bpmndi:BPMNDiagram id="BPMNDiagram_3">
    <bpmndi:BPMNPlane id="BPMNPlane_3" bpmnElement="Collaboration_3">

      <!-- Patient Pool -->
      <bpmndi:BPMNShape id="Participant_Patient3_di" bpmnElement="Participant_Patient3" isHorizontal="true">
        <omgdc:Bounds x="0" y="0" width="1400" height="200"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Start_CheckIn_di" bpmnElement="Start_CheckIn">
        <omgdc:Bounds x="50" y="80" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_WaitVitals_di" bpmnElement="User_WaitVitals">
        <omgdc:Bounds x="130" y="60" width="100" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_WaitConsultation_di" bpmnElement="User_WaitConsultation">
        <omgdc:Bounds x="280" y="60" width="100" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_Consultation_di" bpmnElement="User_Consultation">
        <omgdc:Bounds x="430" y="60" width="100" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_ReceivePrescription_di" bpmnElement="Catch_ReceivePrescription">
        <omgdc:Bounds x="580" y="70" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_FillSection1_di" bpmnElement="User_FillSection1">
        <omgdc:Bounds x="660" y="60" width="100" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_PatientComplete_di" bpmnElement="End_PatientComplete">
        <omgdc:Bounds x="810" y="80" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Nurse Pool -->
      <bpmndi:BPMNShape id="Participant_Nurse_di" bpmnElement="Participant_Nurse" isHorizontal="true">
        <omgdc:Bounds x="0" y="220" width="1400" height="220"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch_PatientArrives_di" bpmnElement="Catch_PatientArrives">
        <omgdc:Bounds x="120" y="320" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_VerifyIdentity_di" bpmnElement="User_VerifyIdentity">
        <omgdc:Bounds x="200" y="300" width="100" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_RecordVitals_di" bpmnElement="User_RecordVitals">
        <omgdc:Bounds x="350" y="300" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordVitalsSystem_di" bpmnElement="Task_RecordVitalsSystem">
        <omgdc:Bounds x="520" y="300" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_EscortPatient_di" bpmnElement="User_EscortPatient">
        <omgdc:Bounds x="690" y="300" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_NurseComplete_di" bpmnElement="End_NurseComplete">
        <omgdc:Bounds x="860" y="320" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Consultant Pool -->
      <bpmndi:BPMNShape id="Participant_Consultant3_di" bpmnElement="Participant_Consultant3" isHorizontal="true">
        <omgdc:Bounds x="0" y="460" width="1400" height="400"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Catch_PatientArrivedConsultant_di" bpmnElement="Catch_PatientArrivedConsultant">
        <omgdc:Bounds x="100" y="560" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ParallelReview_di" bpmnElement="Gateway_ParallelReview" isMarkerVisible="true">
        <omgdc:Bounds x="180" y="550" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewSection1_di" bpmnElement="Task_ReviewSection1">
        <omgdc:Bounds x="270" y="480" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewVitals_di" bpmnElement="Task_ReviewVitals">
        <omgdc:Bounds x="270" y="600" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_JoinReview_di" bpmnElement="Gateway_JoinReview" isMarkerVisible="true">
        <omgdc:Bounds x="430" y="550" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_ConductExam_di" bpmnElement="User_ConductExam">
        <omgdc:Bounds x="520" y="540" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_CompleteSection2_di" bpmnElement="User_CompleteSection2">
        <omgdc:Bounds x="680" y="540" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Diagnosis_di" bpmnElement="Gateway_Diagnosis" isMarkerVisible="true">
        <omgdc:Bounds x="840" y="550" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- Diagnosis branches -->
      <bpmndi:BPMNShape id="User_HypertensionPlan_di" bpmnElement="User_HypertensionPlan">
        <omgdc:Bounds x="930" y="470" width="120" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_HypotensionPlan_di" bpmnElement="User_HypotensionPlan">
        <omgdc:Bounds x="930" y="545" width="120" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_DiabetesPlan_di" bpmnElement="User_DiabetesPlan">
        <omgdc:Bounds x="930" y="620" width="120" height="60"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_GeneralPlan_di" bpmnElement="User_GeneralPlan">
        <omgdc:Bounds x="1090" y="545" width="100" height="60"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_TreatmentJoin_di" bpmnElement="Gateway_TreatmentJoin" isMarkerVisible="true">
        <omgdc:Bounds x="1100" y="470" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GeneratePrescription_di" bpmnElement="Task_GeneratePrescription">
        <omgdc:Bounds x="1190" y="470" width="100" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="User_ScheduleFollowup_di" bpmnElement="User_ScheduleFollowup">
        <omgdc:Bounds x="500" y="680" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SaveRecord_di" bpmnElement="Task_SaveRecord">
        <omgdc:Bounds x="660" y="680" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ConsultantComplete_di" bpmnElement="End_ConsultantComplete">
        <omgdc:Bounds x="820" y="695" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Data Objects -->
      <bpmndi:BPMNShape id="DataObject_Section1_di" bpmnElement="DataObject_Section1">
        <omgdc:Bounds x="380" y="380" width="36" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObject_VitalSigns_di" bpmnElement="DataObject_VitalSigns">
        <omgdc:Bounds x="380" y="470" width="36" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObject_Section2_di" bpmnElement="DataObject_Section2">
        <omgdc:Bounds x="800" y="470" width="36" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObject_Prescription_di" bpmnElement="DataObject_Prescription">
        <omgdc:Bounds x="1100" y="380" width="36" height="50"/>
      </bpmndi:BPMNShape>

      <!-- Sequence Flows Patient -->
      <bpmndi:BPMNEdge id="Flow_P1_di" bpmnElement="Flow_P1">
        <omgdi:waypoint x="86" y="98"/>
        <omgdi:waypoint x="130" y="95"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P2_di" bpmnElement="Flow_P2">
        <omgdi:waypoint x="180" y="95"/>
        <omgdi:waypoint x="280" y="95"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P3_di" bpmnElement="Flow_P3">
        <omgdi:waypoint x="330" y="95"/>
        <omgdi:waypoint x="430" y="95"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P4_di" bpmnElement="Flow_P4">
        <omgdi:waypoint x="480" y="95"/>
        <omgdi:waypoint x="580" y="88"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P5_di" bpmnElement="Flow_P5">
        <omgdi:waypoint x="598" y="88"/>
        <omgdi:waypoint x="660" y="95"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_P6_di" bpmnElement="Flow_P6">
        <omgdi:waypoint x="710" y="95"/>
        <omgdi:waypoint x="810" y="98"/>
      </bpmndi:BPMNEdge>

      <!-- Sequence Flows Nurse -->
      <bpmndi:BPMNEdge id="Flow_N1_di" bpmnElement="Flow_N1">
        <omgdi:waypoint x="138" y="338"/>
        <omgdi:waypoint x="200" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_N2_di" bpmnElement="Flow_N2">
        <omgdi:waypoint x="250" y="335"/>
        <omgdi:waypoint x="350" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_N3_di" bpmnElement="Flow_N3">
        <omgdi:waypoint x="410" y="335"/>
        <omgdi:waypoint x="520" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_N4_di" bpmnElement="Flow_N4">
        <omgdi:waypoint x="580" y="335"/>
        <omgdi:waypoint x="690" y="335"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_N5_di" bpmnElement="Flow_N5">
        <omgdi:waypoint x="750" y="335"/>
        <omgdi:waypoint x="860" y="338"/>
      </bpmndi:BPMNEdge>

      <!-- Sequence Flows Consultant -->
      <bpmndi:BPMNEdge id="Flow_C1_di" bpmnElement="Flow_C1">
        <omgdi:waypoint x="118" y="578"/>
        <omgdi:waypoint x="180" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2a_di" bpmnElement="Flow_C2a">
        <omgdi:waypoint x="205" y="550"/>
        <omgdi:waypoint x="205" y="515"/>
        <omgdi:waypoint x="270" y="515"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C2b_di" bpmnElement="Flow_C2b">
        <omgdi:waypoint x="205" y="600"/>
        <omgdi:waypoint x="205" y="635"/>
        <omgdi:waypoint x="270" y="635"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C3_di" bpmnElement="Flow_C3">
        <omgdi:waypoint x="330" y="515"/>
        <omgdi:waypoint x="405" y="515"/>
        <omgdi:waypoint x="455" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C4_di" bpmnElement="Flow_C4">
        <omgdi:waypoint x="330" y="635"/>
        <omgdi:waypoint x="405" y="635"/>
        <omgdi:waypoint x="455" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C5_di" bpmnElement="Flow_C5">
        <omgdi:waypoint x="480" y="575"/>
        <omgdi:waypoint x="520" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C6_di" bpmnElement="Flow_C6">
        <omgdi:waypoint x="580" y="575"/>
        <omgdi:waypoint x="680" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C7_di" bpmnElement="Flow_C7">
        <omgdi:waypoint x="740" y="575"/>
        <omgdi:waypoint x="840" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8a_di" bpmnElement="Flow_C8a">
        <omgdi:waypoint x="865" y="550"/>
        <omgdi:waypoint x="865" y="500"/>
        <omgdi:waypoint x="930" y="500"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8b_di" bpmnElement="Flow_C8b">
        <omgdi:waypoint x="865" y="575"/>
        <omgdi:waypoint x="930" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8c_di" bpmnElement="Flow_C8c">
        <omgdi:waypoint x="865" y="600"/>
        <omgdi:waypoint x="865" y="650"/>
        <omgdi:waypoint x="930" y="650"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C8d_di" bpmnElement="Flow_C8d">
        <omgdi:waypoint x="890" y="575"/>
        <omgdi:waypoint x="1090" y="575"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C9_di" bpmnElement="Flow_C9">
        <omgdi:waypoint x="990" y="500"/>
        <omgdi:waypoint x="1075" y="500"/>
        <omgdi:waypoint x="1125" y="495"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C10_di" bpmnElement="Flow_C10">
        <omgdi:waypoint x="990" y="575"/>
        <omgdi:waypoint x="1050" y="575"/>
        <omgdi:waypoint x="1125" y="495"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C11_di" bpmnElement="Flow_C11">
        <omgdi:waypoint x="990" y="650"/>
        <omgdi:waypoint x="1075" y="650"/>
        <omgdi:waypoint x="1125" y="495"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C12_di" bpmnElement="Flow_C12">
        <omgdi:waypoint x="1140" y="575"/>
        <omgdi:waypoint x="1125" y="495"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C13_di" bpmnElement="Flow_C13">
        <omgdi:waypoint x="1150" y="495"/>
        <omgdi:waypoint x="1190" y="505"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C14_di" bpmnElement="Flow_C14">
        <omgdi:waypoint x="1190" y="505"/>
        <omgdi:waypoint x="560" y="715"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C15_di" bpmnElement="Flow_C15">
        <omgdi:waypoint x="560" y="715"/>
        <omgdi:waypoint x="660" y="715"/>
