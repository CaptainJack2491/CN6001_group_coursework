</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_PatientDone_di" bpmnElement="End_PatientDone">
<omgdc:Bounds x="320" y="530" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Patient receives final notification -->
<bpmndi:BPMNShape id="Start_PatientFormComplete_di" bpmnElement="Start_PatientFormComplete">
<omgdc:Bounds x="450" y="530" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_PatientComplete_di" bpmnElement="End_PatientComplete">
<omgdc:Bounds x="540" y="530" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Consultant Pool -->
