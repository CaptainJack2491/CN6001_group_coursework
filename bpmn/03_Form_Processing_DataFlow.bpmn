</bpmndi:BPMNShape>

<!-- Patient Pool -->
<bpmndi:BPMNShape id="Participant_ExternalPatient_di" bpmnElement="Participant_ExternalPatient" isHorizontal="true">
<omgdc:Bounds x="0" y="480" width="600" height="180"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_PatientNotified_di" bpmnElement="Start_PatientNotified">
