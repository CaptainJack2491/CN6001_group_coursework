</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_Consultant_di" bpmnElement="End_Consultant">
        <omgdc:Bounds x="1210" y="745" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Data Objects -->
      <bpmndi:BPMNShape id="DataObject_Section1_di" bpmnElement="DataObject_Section1">
        <omgdc:Bounds x="400" y="30" width="36" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObject_VitalSigns_di" bpmnElement="DataObject_VitalSigns">
