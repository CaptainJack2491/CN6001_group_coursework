<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
id="Definitions_1"
targetNamespace="http://bpmn.io/schema/bpmn">

<collaboration id="Collaboration_1">
<participant id="Participant_Patient" name="Patient" processRef="Process_Patient"/>
<participant id="Participant_Nurse" name="Nurse/Admin Staff" processRef="Process_Nurse"/>
<participant id="Participant_Consultant" name="Consultant" processRef="Process_Consultant"/>
<messageFlow id="MessageFlow_1" sourceRef="Task_VerifyIdentity" targetRef="Task_FillForm"/>
<messageFlow id="MessageFlow_2" sourceRef="Task_RecordVitals" targetRef="Start_ConsultReady"/>
<messageFlow id="MessageFlow_3" sourceRef="Task_EscortToConsultant" targetRef="Start_PatientReady"/>
</collaboration>

<!-- Patient Process -->
<process id="Process_Patient" isExecutable="false">
<startEvent id="Start_Arrive" name="Arrive at Clinic"/>
<sequenceFlow id="Flow_1" sourceRef="Start_Arrive" targetRef="Task_Login"/>

<userTask id="Task_Login" name="Login to Portal/Register"/>
<sequenceFlow id="Flow_2" sourceRef="Task_Login" targetRef="Task_FillForm"/>

<userTask id="Task_FillForm" name="Fill Section 1 Form&#10;(symptoms, personal info, medical history)"/>
<sequenceFlow id="Flow_3" sourceRef="Task_FillForm" targetRef="Gateway_FormComplete"/>

<exclusiveGateway id="Gateway_FormComplete" name="Form Complete?"/>
<sequenceFlow id="Flow_4" name="No" sourceRef="Gateway_FormComplete" targetRef="Task_CompleteMissing">
<conditionExpression xsi:type="tFormalExpression">${!formComplete}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_5" name="Yes" sourceRef="Gateway_FormComplete" targetRef="Task_SubmitForm">
<conditionExpression xsi:type="tFormalExpression">${formComplete}</conditionExpression>
</sequenceFlow>

<userTask id="Task_CompleteMissing" name="Complete Missing Fields"/>
<sequenceFlow id="Flow_6" sourceRef="Task_CompleteMissing" targetRef="Task_FillForm"/>

<userTask id="Task_SubmitForm" name="Submit Form"/>
<sequenceFlow id="Flow_7" sourceRef="Task_SubmitForm" targetRef="Task_WaitVitals"/>

<userTask id="Task_WaitVitals" name="Wait for Vital Signs Check"/>
<sequenceFlow id="Flow_8" sourceRef="Task_WaitVitals" targetRef="Task_Consultation"/>

<userTask id="Task_Consultation" name="Consultation with Specialist"/>
<sequenceFlow id="Flow_9" sourceRef="Task_Consultation" targetRef="Task_ReceivePrescription"/>

<userTask id="Task_ReceivePrescription" name="Receive Prescription"/>
<sequenceFlow id="Flow_10" sourceRef="Task_ReceivePrescription" targetRef="End_Process"/>

<endEvent id="End_Process" name="Consultation Complete"/>
</process>

<!-- Nurse/Admin Process -->
<process id="Process_Nurse" isExecutable="false">
<startEvent id="Start_PatientArrives" name="Patient Arrives"/>
<sequenceFlow id="Flow_11" sourceRef="Start_PatientArrives" targetRef="Task_VerifyIdentity"/>

<userTask id="Task_VerifyIdentity" name="Verify Patient Identity"/>
<sequenceFlow id="Flow_12" sourceRef="Task_VerifyIdentity" targetRef="Gateway_VitalsSplit"/>

<!-- PARALLEL GATEWAY: Check BP AND BMI AND Blood Sugar simultaneously -->
<parallelGateway id="Gateway_VitalsSplit" name="Check All Vitals?"/>
<sequenceFlow id="Flow_13a" sourceRef="Gateway_VitalsSplit" targetRef="Task_CheckBP"/>
<sequenceFlow id="Flow_13b" sourceRef="Gateway_VitalsSplit" targetRef="Task_CheckBMI"/>
<sequenceFlow id="Flow_13c" sourceRef="Gateway_VitalsSplit" targetRef="Task_CheckBloodSugar"/>

<userTask id="Task_CheckBP" name="Check Blood Pressure"/>
<sequenceFlow id="Flow_14a" sourceRef="Task_CheckBP" targetRef="Gateway_VitalsJoin"/>

<userTask id="Task_CheckBMI" name="Check BMI"/>
<sequenceFlow id="Flow_14b" sourceRef="Task_CheckBMI" targetRef="Gateway_VitalsJoin"/>

<userTask id="Task_CheckBloodSugar" name="Check Blood Sugar"/>
<sequenceFlow id="Flow_14c" sourceRef="Task_CheckBloodSugar" targetRef="Gateway_VitalsJoin"/>

<!-- PARALLEL GATEWAY JOIN: Wait for all vitals -->
<parallelGateway id="Gateway_VitalsJoin" name="All Vitals Recorded?"/>
<sequenceFlow id="Flow_15" sourceRef="Gateway_VitalsJoin" targetRef="Task_RecordVitals"/>

<userTask id="Task_RecordVitals" name="Record Vital Signs in System"/>
<sequenceFlow id="Flow_16" sourceRef="Task_RecordVitals" targetRef="Task_EscortToConsultant"/>

<userTask id="Task_EscortToConsultant" name="Escort to Consultant"/>
<sequenceFlow id="Flow_17" sourceRef="Task_EscortToConsultant" targetRef="End_Nurse"/>

<endEvent id="End_Nurse" name="Handover Complete"/>
</process>

<!-- Consultant Process -->
<process id="Process_Consultant" isExecutable="false">
<startEvent id="Start_ConsultReady" name="Patient Ready for Consultation">
<messageEventDefinition id="MessageEventDef_1"/>
</startEvent>
<sequenceFlow id="Flow_20" sourceRef="Start_ConsultReady" targetRef="Task_ReviewSection1"/>

<userTask id="Task_ReviewSection1" name="Review Section 1&#10;(Patient Data)"/>
<sequenceFlow id="Flow_21" sourceRef="Task_ReviewSection1" targetRef="Task_ConductExam"/>

<userTask id="Task_ConductExam" name="Conduct Examination"/>
<sequenceFlow id="Flow_22" sourceRef="Task_ConductExam" targetRef="Task_CompleteSection2"/>

<userTask id="Task_CompleteSection2" name="Complete Section 2&#10;(Consultant Notes)"/>
<sequenceFlow id="Flow_23" sourceRef="Task_CompleteSection2" targetRef="Gateway_Diagnosis"/>

<exclusiveGateway id="Gateway_Diagnosis" name="Diagnosis Required?"/>
<sequenceFlow id="Flow_24a" name="Hypertension" sourceRef="Gateway_Diagnosis" targetRef="Task_HypertensionPlan">
<conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypertension'}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_24b" name="Hypotension" sourceRef="Gateway_Diagnosis" targetRef="Task_HypotensionPlan">
<conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypotension'}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_24c" name="Diabetes" sourceRef="Gateway_Diagnosis" targetRef="Task_DiabetesPlan">
<conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Diabetes'}</conditionExpression>
</sequenceFlow>

<userTask id="Task_HypertensionPlan" name="Hypertension Treatment Plan"/>
<sequenceFlow id="Flow_25a" sourceRef="Task_HypertensionPlan" targetRef="Gateway_DiagnosisJoin"/>

<userTask id="Task_HypotensionPlan" name="Hypotension Treatment Plan"/>
<sequenceFlow id="Flow_25b" sourceRef="Task_HypotensionPlan" targetRef="Gateway_DiagnosisJoin"/>

<userTask id="Task_DiabetesPlan" name="Diabetes Management Plan"/>
<sequenceFlow id="Flow_25c" sourceRef="Task_DiabetesPlan" targetRef="Gateway_DiagnosisJoin"/>

<!-- CONVERGING GATEWAY: Join diagnosis branches -->
<parallelGateway id="Gateway_DiagnosisJoin" name="Treatment Planned"/>
<sequenceFlow id="Flow_26" sourceRef="Gateway_DiagnosisJoin" targetRef="Task_GeneratePrescription"/>

<serviceTask id="Task_GeneratePrescription" name="Generate Prescription"/>
<sequenceFlow id="Flow_27" sourceRef="Task_GeneratePrescription" targetRef="Task_ScheduleFollowup"/>

<userTask id="Task_ScheduleFollowup" name="Schedule Follow-up"/>
<sequenceFlow id="Flow_28" sourceRef="Task_ScheduleFollowup" targetRef="Task_SaveRecord"/>

<serviceTask id="Task_SaveRecord" name="Save Medical Record"/>
<sequenceFlow id="Flow_29" sourceRef="Task_SaveRecord" targetRef="End_Consultant"/>

<endEvent id="End_Consultant" name="Consultation Complete"/>
</process>

<bpmndi:BPMNDiagram id="BPMNDiagram_1">
<bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

<!-- Patient Pool -->
<bpmndi:BPMNShape id="Participant_Patient_di" bpmnElement="Participant_Patient" isHorizontal="true">
<omgdc:Bounds x="0" y="0" width="1400" height="250"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_Arrive_di" bpmnElement="Start_Arrive">
