<bpmndi:BPMNShape id="Gateway_VitalsJoin_di" bpmnElement="Gateway_VitalsJoin" isMarkerVisible="true">
<omgdc:Bounds x="540" y="393" width="50" height="50"/>
</bpmndi:BPMNShape>

<!-- Service task for automated recording -->
<bpmndi:BPMNShape id="Task_RecordVitals_di" bpmnElement="Task_RecordVitals">
<omgdc:Bounds x="630" y="378" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_EscortToConsultant_di" bpmnElement="Task_EscortToConsultant">
<omgdc:Bounds x="800" y="378" width="120" height="80"/>
</bpmndi:BPMNShape>
