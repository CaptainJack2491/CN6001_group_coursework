<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
id="Definitions_1"
targetNamespace="http://bpmn.io/schema/bpmn">

<collaboration id="Collaboration_1">
<participant id="Participant_Patient" name="Patient" processRef="Process_Patient"/>
<participant id="Participant_Nurse" name="Nurse/Admin Staff" processRef="Process_Nurse"/>
<participant id="Participant_Consultant" name="Consultant" processRef="Process_Consultant"/>
<!-- Message flows between pools -->
<messageFlow id="MessageFlow_FormReady" sourceRef="Task_SubmitForm" targetRef="Start_PatientArrives"/>
<messageFlow id="MessageFlow_VitalsReady" sourceRef="Task_RecordVitals" targetRef="Start_ConsultReady"/>
<messageFlow id="MessageFlow_EscortPatient" sourceRef="Task_EscortToConsultant" targetRef="Catch_PatientArrived"/>
<messageFlow id="MessageFlow_PrescriptionSent" sourceRef="Task_GeneratePrescription" targetRef="Catch_Prescription"/>
</collaboration>

<!-- Patient Process -->
<process id="Process_Patient" isExecutable="false">
<startEvent id="Start_Arrive" name="Arrive at Clinic"/>
<sequenceFlow id="Flow_1" sourceRef="Start_Arrive" targetRef="Task_Login"/>

<userTask id="Task_Login" name="Login to Portal/Register"/>
<sequenceFlow id="Flow_2" sourceRef="Task_Login" targetRef="Task_FillForm"/>

<userTask id="Task_FillForm" name="Fill Section 1 Form&#10;(symptoms, personal info, medical history)"/>
<sequenceFlow id="Flow_3" sourceRef="Task_FillForm" targetRef="Gateway_FormComplete"/>

<exclusiveGateway id="Gateway_FormComplete" name="Form Complete?"/>
<sequenceFlow id="Flow_4" name="No" sourceRef="Gateway_FormComplete" targetRef="Task_CompleteMissing">
<conditionExpression xsi:type="tFormalExpression">${!formComplete}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_5" name="Yes" sourceRef="Gateway_FormComplete" targetRef="Task_SubmitForm">
<conditionExpression xsi:type="tFormalExpression">${formComplete}</conditionExpression>
</sequenceFlow>

<userTask id="Task_CompleteMissing" name="Complete Missing Fields"/>
<sequenceFlow id="Flow_6" sourceRef="Task_CompleteMissing" targetRef="Task_FillForm"/>

<userTask id="Task_SubmitForm" name="Submit Form"/>
<sequenceFlow id="Flow_7" sourceRef="Task_SubmitForm" targetRef="Catch_WaitVitals"/>

<!-- Patient waits for vitals check - receive task (intermediate catch) -->
<intermediateCatchEvent id="Catch_WaitVitals" name="Wait for&#10;Vital Signs Check">
<messageEventDefinition id="MsgDef_WaitVitals"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_8" sourceRef="Catch_WaitVitals" targetRef="Catch_Consultation"/>

<!-- Patient waits to be called for consultation -->
<intermediateCatchEvent id="Catch_Consultation" name="Called for&#10;Consultation">
<messageEventDefinition id="MsgDef_Consultation"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_9" sourceRef="Catch_Consultation" targetRef="Catch_ReceivePrescription"/>

<!-- Patient receives prescription - receive task -->
<intermediateCatchEvent id="Catch_ReceivePrescription" name="Receive&#10;Prescription">
<messageEventDefinition id="MsgDef_Prescription"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_10" sourceRef="Catch_ReceivePrescription" targetRef="End_Process"/>

<endEvent id="End_Process" name="Consultation Complete"/>
</process>

<!-- Nurse/Admin Process -->
<process id="Process_Nurse" isExecutable="false">
<startEvent id="Start_PatientArrives" name="Patient Arrives">
<messageEventDefinition id="MsgDef_PatientArrives"/>
</startEvent>
<sequenceFlow id="Flow_11" sourceRef="Start_PatientArrives" targetRef="Task_VerifyIdentity"/>

<userTask id="Task_VerifyIdentity" name="Verify Patient Identity"/>
<sequenceFlow id="Flow_12" sourceRef="Task_VerifyIdentity" targetRef="Gateway_VitalsSplit"/>

<!-- PARALLEL GATEWAY: Check BP AND BMI AND Blood Sugar simultaneously -->
<parallelGateway id="Gateway_VitalsSplit" name="Check All Vitals?"/>
<sequenceFlow id="Flow_13a" sourceRef="Gateway_VitalsSplit" targetRef="Task_CheckBP"/>
<sequenceFlow id="Flow_13b" sourceRef="Gateway_VitalsSplit" targetRef="Task_CheckBMI"/>
<sequenceFlow id="Flow_13c" sourceRef="Gateway_VitalsSplit" targetRef="Task_CheckBloodSugar"/>

<userTask id="Task_CheckBP" name="Check Blood Pressure"/>
<sequenceFlow id="Flow_14a" sourceRef="Task_CheckBP" targetRef="Gateway_VitalsJoin"/>

<userTask id="Task_CheckBMI" name="Check BMI"/>
<sequenceFlow id="Flow_14b" sourceRef="Task_CheckBMI" targetRef="Gateway_VitalsJoin"/>

<userTask id="Task_CheckBloodSugar" name="Check Blood Sugar"/>
<sequenceFlow id="Flow_14c" sourceRef="Task_CheckBloodSugar" targetRef="Gateway_VitalsJoin"/>

<!-- PARALLEL GATEWAY JOIN: Wait for all vitals -->
<parallelGateway id="Gateway_VitalsJoin" name="All Vitals Recorded?"/>
<sequenceFlow id="Flow_15" sourceRef="Gateway_VitalsJoin" targetRef="Task_RecordVitals"/>

<!-- Service task - automated system recording -->
<serviceTask id="Task_RecordVitals" name="Record Vital Signs in System"/>
<sequenceFlow id="Flow_16" sourceRef="Task_RecordVitals" targetRef="Task_EscortToConsultant"/>

<userTask id="Task_EscortToConsultant" name="Escort to Consultant"/>
<sequenceFlow id="Flow_17" sourceRef="Task_EscortToConsultant" targetRef="End_Nurse"/>

<endEvent id="End_Nurse" name="Handover Complete"/>
</process>

<!-- Consultant Process -->
<process id="Process_Consultant" isExecutable="false">
<!-- Start event triggered by message from nurse - patient is ready -->
<startEvent id="Start_ConsultReady" name="Patient Ready for Consultation">
<messageEventDefinition id="MsgDef_ConsultReady"/>
</startEvent>
<sequenceFlow id="Flow_20" sourceRef="Start_ConsultReady" targetRef="Catch_PatientArrived"/>

<!-- Intermediate catch - consultant waits for patient to arrive -->
<intermediateCatchEvent id="Catch_PatientArrived" name="Patient&#10;Arrived">
<messageEventDefinition id="MsgDef_PatientHere"/>
</intermediateCatchEvent>
<sequenceFlow id="Flow_21" sourceRef="Catch_PatientArrived" targetRef="Task_ReviewSection1"/>

<userTask id="Task_ReviewSection1" name="Review Section 1&#10;(Patient Data)"/>
<sequenceFlow id="Flow_22" sourceRef="Task_ReviewSection1" targetRef="Task_ConductExam"/>

<userTask id="Task_ConductExam" name="Conduct Examination"/>
<sequenceFlow id="Flow_23" sourceRef="Task_ConductExam" targetRef="Task_CompleteSection2"/>

<userTask id="Task_CompleteSection2" name="Complete Section 2&#10;(Consultant Notes)"/>
<sequenceFlow id="Flow_24" sourceRef="Task_CompleteSection2" targetRef="Gateway_ConditionType"/>

<!-- Exclusive gateway - condition type determines treatment path -->
<exclusiveGateway id="Gateway_ConditionType" name="Condition Type?"/>
<sequenceFlow id="Flow_25a" name="Hypertension" sourceRef="Gateway_ConditionType" targetRef="Task_HypertensionPlan">
<conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypertension'}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_25b" name="Hypotension" sourceRef="Gateway_ConditionType" targetRef="Task_HypotensionPlan">
<conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Hypotension'}</conditionExpression>
</sequenceFlow>
<sequenceFlow id="Flow_25c" name="Diabetes" sourceRef="Gateway_ConditionType" targetRef="Task_DiabetesPlan">
<conditionExpression xsi:type="tFormalExpression">${diagnosis == 'Diabetes'}</conditionExpression>
</sequenceFlow>

<userTask id="Task_HypertensionPlan" name="Hypertension Treatment Plan"/>
<sequenceFlow id="Flow_26a" sourceRef="Task_HypertensionPlan" targetRef="Gateway_TreatmentJoin"/>

<userTask id="Task_HypotensionPlan" name="Hypotension Treatment Plan"/>
<sequenceFlow id="Flow_26b" sourceRef="Task_HypotensionPlan" targetRef="Gateway_TreatmentJoin"/>

<userTask id="Task_DiabetesPlan" name="Diabetes Management Plan"/>
<sequenceFlow id="Flow_26c" sourceRef="Task_DiabetesPlan" targetRef="Gateway_TreatmentJoin"/>

<!-- CONVERGING EXCLUSIVE GATEWAY: Join diagnosis branches (only one path taken) -->
<exclusiveGateway id="Gateway_TreatmentJoin" name="Treatment Planned"/>
<sequenceFlow id="Flow_27" sourceRef="Gateway_TreatmentJoin" targetRef="Task_GeneratePrescription"/>

<!-- Service task - automated prescription generation -->
<serviceTask id="Task_GeneratePrescription" name="Generate Prescription"/>
<sequenceFlow id="Flow_28" sourceRef="Task_GeneratePrescription" targetRef="Task_ScheduleFollowup"/>

<userTask id="Task_ScheduleFollowup" name="Schedule Follow-up"/>
<sequenceFlow id="Flow_29" sourceRef="Task_ScheduleFollowup" targetRef="Task_SaveRecord"/>

<!-- Service task - automated database save -->
<serviceTask id="Task_SaveRecord" name="Save Medical Record"/>
<sequenceFlow id="Flow_30" sourceRef="Task_SaveRecord" targetRef="End_Consultant"/>

<endEvent id="End_Consultant" name="Consultation Complete"/>
  </process>

  <!-- Data Objects (required by Case Study) -->
  <dataObject id="DataObject_Section1" name="Section 1 Form"/>
  <dataObject id="DataObject_VitalSigns" name="Vital Signs Record"/>
  <dataObject id="DataObject_Section2" name="Section 2 Form"/>
  <dataObject id="DataObject_Prescription" name="Prescription"/>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
<bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">

<!-- Patient Pool -->
<bpmndi:BPMNShape id="Participant_Patient_di" bpmnElement="Participant_Patient" isHorizontal="true">
<omgdc:Bounds x="0" y="0" width="1400" height="280"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_Arrive_di" bpmnElement="Start_Arrive">
<omgdc:Bounds x="50" y="100" width="36" height="36"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_Login_di" bpmnElement="Task_Login">
<omgdc:Bounds x="120" y="78" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_FillForm_di" bpmnElement="Task_FillForm">
<omgdc:Bounds x="280" y="78" width="140" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Gateway_FormComplete_di" bpmnElement="Gateway_FormComplete" isMarkerVisible="true">
<omgdc:Bounds x="460" y="95" width="50" height="50"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_CompleteMissing_di" bpmnElement="Task_CompleteMissing">
<omgdc:Bounds x="425" y="200" width="120" height="60"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_SubmitForm_di" bpmnElement="Task_SubmitForm">
<omgdc:Bounds x="560" y="78" width="100" height="80"/>
</bpmndi:BPMNShape>

<!-- Receive task for waiting -->
<bpmndi:BPMNShape id="Catch_WaitVitals_di" bpmnElement="Catch_WaitVitals">
<omgdc:Bounds x="700" y="100" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Receive task for consultation call -->
<bpmndi:BPMNShape id="Catch_Consultation_di" bpmnElement="Catch_Consultation">
<omgdc:Bounds x="860" y="100" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Receive task for prescription -->
<bpmndi:BPMNShape id="Catch_ReceivePrescription_di" bpmnElement="Catch_ReceivePrescription">
<omgdc:Bounds x="1020" y="100" width="36" height="36"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="End_Process_di" bpmnElement="End_Process">
<omgdc:Bounds x="1180" y="100" width="36" height="36"/>
</bpmndi:BPMNShape>

<!-- Nurse Pool -->
<bpmndi:BPMNShape id="Participant_Nurse_di" bpmnElement="Participant_Nurse" isHorizontal="true">
<omgdc:Bounds x="0" y="280" width="1400" height="280"/>
</bpmndi:BPMNShape>

<bpmndi:BPMNShape id="Start_PatientArrives_di" bpmnElement="Start_PatientArrives">
