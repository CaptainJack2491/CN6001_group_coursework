</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_SubmitForm_di" bpmnElement="Task_SubmitForm">
<omgdc:Bounds x="560" y="78" width="100" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_WaitVitals_di" bpmnElement="Task_WaitVitals">
<omgdc:Bounds x="700" y="78" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_Consultation_di" bpmnElement="Task_Consultation">
<omgdc:Bounds x="860" y="78" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="Task_ReceivePrescription_di" bpmnElement="Task_ReceivePrescription">
<omgdc:Bounds x="1020" y="78" width="120" height="80"/>
</bpmndi:BPMNShape>
<bpmndi:BPMNShape id="End_Process_di" bpmnElement="End_Process">
<omgdc:Bounds x="1180" y="100" width="36" height="36"/>
</bpmndi:BPMNShape>

